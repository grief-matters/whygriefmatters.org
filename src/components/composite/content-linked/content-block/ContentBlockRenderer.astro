---
import { getEntry, type ReferenceDataEntry } from "astro:content";

import Container from "@ui/base/Container.astro";
import PortableTextContentBlock from "@ui/base/PortableTextContentBlock.astro";
import Typography, {
  type TypographyTextElement,
} from "@ui/base/Typography.astro";
import FeaturedResourceRenderer from "../internet-resources/FeaturedResourceRenderer.astro";
import Slider from "@ui/layouts/slider/Slider.astro";
import Slide from "@ui/layouts/slider/Slide.astro";
import { assertNever } from "@ui/utils/ts-utils";
import FeaturedNavListItem from "../FeaturedNavListItem.astro";
import EmphasizedNavListItem from "../EmphasizedNavListItem.astro";
import ImageRowRenderer from "./ImageRowRenderer.astro";
import type { ContentBlockHeadingLevel } from "@content/model/shared/headingLevel";
import type { TextPreset } from "@styles/utils/typography";

interface Props {
  contentBlockRef: ReferenceDataEntry<"contentBlocks", string>;
  textAlign?: "center" | "left";
}

const { contentBlockRef, textAlign = "center" } = Astro.props;

const contentBlock = await getEntry(contentBlockRef);

const headingLevelElMap: Record<
  ContentBlockHeadingLevel,
  TypographyTextElement
> = {
  h1: "h2",
  h2: "h3",
};

const headingLevelTextPresetMap: Record<ContentBlockHeadingLevel, TextPreset> =
  {
    h1: "title-2",
    h2: "title-4",
  };
---

{
  contentBlock.data.content.map((contentItem) => {
    switch (contentItem.contentType) {
      case "headingText":
        return (
          <Container paddingX={3}>
            <Typography
              as={headingLevelElMap[contentItem.headingLevel]}
              variant={headingLevelTextPresetMap[contentItem.headingLevel]}
              textAlign="center"
            >
              {contentItem.text}
            </Typography>
          </Container>
        );
      case "richTextContentBlock":
        return (
          <Container paddingX={3}>
            <PortableTextContentBlock
              textAlign={textAlign}
              portableText={contentItem.portableText}
              textVariant={
                contentItem.emphasized ? "prominent-first" : "body-1"
              }
            />
          </Container>
        );
      case "richTextWithHeading":
        return (
          <Container paddingX={3}>
            <Typography
              as={headingLevelElMap[contentItem.headingLevel]}
              variant="title-3"
              textAlign="center"
            >
              {contentItem.headingText}
            </Typography>
            <PortableTextContentBlock
              textAlign={textAlign}
              portableText={contentItem.portableText}
            />
          </Container>
        );
      case "featuredResource":
        return (
          <Container>
            <FeaturedResourceRenderer
              resourceRef={contentItem.refId}
              resourceType={contentItem.refType}
            />
          </Container>
        );
      case "featuredNavItems":
        return (
          <div class="max-w-6xl xl:mx-auto">
            <div class="w-full overflow-hidden md:overflow-visible">
              <div
                class:list={[
                  "flex overflow-x-auto snap-x snap-mandatory scroll-smooth",
                  "md:grid md:grid-cols-3 md:gap-4 md:overflow-visible",
                ]}
              >
                {contentItem.items.map((item) => (
                  <div
                    class:list={[
                      "basis-xs shrink-0 grow snap-center max-w-sm px-1 py-2",
                      "md:basis-auto md:max-w-none md:p-0",
                    ]}
                  >
                    <FeaturedNavListItem fullHeight item={item} />
                  </div>
                ))}
              </div>
            </div>
          </div>
        );
      case "featuredResources":
        return (
          <Slider>
            {contentItem.resources.map((resource) => (
              <Slide paddingX={1} paddingY={2}>
                <FeaturedResourceRenderer
                  fullHeight
                  resourceRef={resource.refId}
                  resourceType={resource.refType}
                />
              </Slide>
            ))}
          </Slider>
        );
      case "imageRow":
        return <ImageRowRenderer imageRefs={contentItem.images} />;
      case "navItems":
        return (
          <Container paddingX={3}>
            <div class="flex flex-wrap justify-center gap-3 pb-4">
              {contentItem.items.map((item) => (
                <EmphasizedNavListItem item={item} />
              ))}
            </div>
          </Container>
        );
      case "navItem": {
        const { contentType: _contentType, ...navItem } = contentItem;
        return (
          <Container paddingX={3}>
            <div class="flex justify-center">
              <EmphasizedNavListItem item={{ kind: "navItem", ...navItem }} />
            </div>
          </Container>
        );
      }
      case "person":
      case "personGroup":
      case "resourceLinks":
      case "staticNavItem":
      case "imageAsset":
        return <div>todo</div>;
      default:
        assertNever(contentItem);
    }
  })
}
