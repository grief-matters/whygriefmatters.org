---
import { getEntry } from "astro:content";

import Stack from "@ui/base/Stack.astro";
import Typography from "@ui/base/Typography.astro";

const { personGroupRef } = Astro.props;

const personGroupEntry = await getEntry("personGroups", personGroupRef);

const groupMembers = personGroupEntry?.data.members
  ? await Promise.all(
      personGroupEntry.data.members.map((member) =>
        getEntry(member.collection, member.id),
      ),
    )
  : [];
---

<Stack marginBottom={6} class="break-inside-avoid">
  <Typography variant="title-5">
    {personGroupEntry?.data.name}
  </Typography>
  <Typography variant="subtitle-1">
    {personGroupEntry?.data.description}
  </Typography>
  {
    groupMembers.map((member) => (
      <Typography variant="body-1" marginBottom={1}>
        {member?.data.fullName}
      </Typography>
    ))
  }
</Stack>
