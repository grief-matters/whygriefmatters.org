---
import { getEntry, type CollectionEntry } from "astro:content";

import Typography from "@ui/base/Typography.astro";
import Stack from "@ui/base/Stack.astro";
import Icon from "@ui/base/Icon.astro";
import { getSourceFromResourceUrl } from "@ui/utils/content/content";
import { getResourceFilterAttrs } from "@ui/utils/content/resourceFilterAttrs";
import { getLocaleDateStringFromIsoString } from "@ui/utils/date";
import { isLink, type Link } from "@ui/utils/link";
import { resourceTypeIconConfigMap } from "@ui/utils/icon";

import LinkComp from "@ui/base/Link.astro";

interface Props {
  entry: CollectionEntry<"books">;
}

const { entry } = Astro.props;

const lastReviewedDate = getLocaleDateStringFromIsoString(entry.data.updatedAt);

let source: Link | null = null;
if (entry.data.sourceOrgId) {
  const sourceWebsiteEntry = await getEntry(entry.data.sourceOrgId);
  source = {
    label: sourceWebsiteEntry.data.title,
    url: sourceWebsiteEntry.data.resourceUrl,
  };
}

const processedSource: string | Link | null =
  source ?? getSourceFromResourceUrl(entry.data.resourceUrl);

const iconConfig = resourceTypeIconConfigMap["book"];
const coverUrl = entry.data.coverUrl;

const filterAttrs = await getResourceFilterAttrs(entry);
---

<article {...filterAttrs} id={entry.id}>
  <Stack>
    <header class="flex flex-col space-y-1.5">
      <div>
        <LinkComp external variant="title-4" to={entry.data.resourceUrl}>
          <h4 id={entry.id} class="inline m-0" set:text={entry.data.title} />
          <span class="inline-block">
            <Icon
              size={2}
              colorVariant="primary"
              getIcon={(icons) => icons.arrowTopRightOnSquare}
            />
          </span>
        </LinkComp>
      </div>
      <div class:list={["space-y-1.5", "md:flex md:gap-1.5"]}>
        <div class:list={["flex gap-1.5 items-center"]}>
          <Icon
            colorVariant={iconConfig.colorVariant}
            getIcon={() => iconConfig.icon}
            size={1}
            display="inline"
          />
          {
            entry.data.author ? (
              <Typography
                variant="subtitle-1"
                set:text={`By ${entry.data.author},`}
              />
            ) : (
              processedSource !== null && (
                <Typography variant="subtitle-1">
                  {"From "}
                  {isLink(processedSource) ? (
                    <LinkComp
                      external
                      variant="subtitle-1"
                      to={processedSource.url}
                      label={processedSource.label}
                    />
                  ) : (
                    <span set:text={processedSource} />
                  )}
                  {","}
                </Typography>
              )
            )
          }
        </div>
        {
          lastReviewedDate && (
            <Typography variant="subtitle-1">
              {"last reviewed "}
              <time datetime={entry.data.updatedAt}>{lastReviewedDate}</time>
            </Typography>
          )
        }
      </div>
    </header>

    <div class="flex flex-col sm:flex-row gap-6">
      {
        coverUrl && (
          <div class="shrink-0">
            <img
              src={coverUrl}
              alt={`${entry.data.title} book cover`}
              width="100"
              height="150"
              class="rounded-md"
              loading="lazy"
            />
          </div>
        )
      }
      <Stack spacing={3}>
        {
          entry.data.description && (
            <Typography>{entry.data.description}</Typography>
          )
        }
        <div class="flex flex-wrap items-center gap-3">
          {
            entry.data.amazonUrl && (
              <a
                class="block"
                rel="noopener noreferrer"
                target="_blank"
                href={entry.data.amazonUrl}
              >
                <span class="sr-only">Buy on Amazon</span>
                <img
                  class="h-10 p-1.5 border border-line-neutral--muted rounded-md"
                  height="40"
                  src="/img/amazon.svg"
                  alt=""
                />
              </a>
            )
          }
        </div>
      </Stack>
    </div>
  </Stack>
</article>
