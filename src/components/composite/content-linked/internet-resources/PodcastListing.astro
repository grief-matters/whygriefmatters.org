---
import { getEntry, type CollectionEntry } from "astro:content";

import Badge from "@ui/base/Badge.astro";
import Typography from "@ui/base/Typography.astro";
import Stack from "@ui/base/Stack.astro";
import Icon from "@ui/base/Icon.astro";
import { getSourceFromResourceUrl } from "@ui/utils/content/content";
import { getLocaleDateStringFromIsoString } from "@ui/utils/date";
import { isLink, type Link } from "@ui/utils/link";
import { resourceTypeIconConfigMap } from "@ui/utils/icon";

import LinkComp from "@ui/base/Link.astro";

interface Props {
  entry: CollectionEntry<"podcasts">;
}

const { entry } = Astro.props;

const lastReviewedDate = getLocaleDateStringFromIsoString(entry.data.updatedAt);

let source: Link | null = null;
if (entry.data.sourceWebsiteId) {
  const sourceWebsiteEntry = await getEntry(entry.data.sourceWebsiteId);
  source = {
    label: sourceWebsiteEntry.data.title,
    url: sourceWebsiteEntry.data.resourceUrl,
  };
}

let processedSource: string | Link | null = source;
if (processedSource === null) {
  const resourceUrl =
    entry.data.resourceUrl ?? entry.data.appleUrl ?? entry.data.spotifyUrl;

  if (resourceUrl === null) {
    return;
  }

  processedSource = getSourceFromResourceUrl(resourceUrl);
}

const iconConfig = resourceTypeIconConfigMap["podcast"];
const artworkUrl = entry.data.applePodcastArtworkUrl;
---

<article id={entry.id} data-pagefind-body>
  <Stack spacing={2}>
    <header class="flex flex-col space-y-1.5">
      <div class="mb-1.5">
        {
          entry.data.resourceUrl ? (
            <LinkComp external variant="title-4" to={entry.data.resourceUrl}>
              <h4
                id={entry.id}
                class="inline m-0"
                set:text={entry.data.title}
              />
              <span class="inline-block">
                <Icon
                  size={2}
                  colorVariant="primary"
                  getIcon={(icons) => icons.arrowTopRightOnSquare}
                />
              </span>
            </LinkComp>
          ) : (
            <Typography as="h4" variant="title-4">
              {entry.data.title}
            </Typography>
          )
        }
      </div>
      <div
        data-pagefind-ignore="index"
        class:list={["space-y-1.5", "md:flex md:gap-1.5"]}
      >
        {
          processedSource !== null && (
            <div class:list={["flex gap-1.5 items-center"]}>
              <Icon
                colorVariant={iconConfig.colorVariant}
                getIcon={() => iconConfig.icon}
                size={1}
                display="inline"
              />
              <Typography variant="subtitle-1">
                {"From "}
                {isLink(processedSource) ? (
                  // Render a link if we managed to process one
                  <LinkComp
                    external
                    variant="subtitle-1"
                    to={processedSource.url}
                    label={processedSource.label}
                  />
                ) : (
                  // Render just text if we fail to get a linkable source
                  <span set:text={processedSource} />
                )}
                {","}
              </Typography>
            </div>
          )
        }
        {
          lastReviewedDate && (
            <Typography variant="subtitle-1">
              {"last reviewed "}
              <time datetime={entry.data.updatedAt}>{lastReviewedDate}</time>
            </Typography>
          )
        }
      </div>
    </header>

    <div class="flex flex-col sm:flex-row gap-6">
      {
        artworkUrl && (
          <div class="shrink-0">
            <img
              src={artworkUrl}
              alt={`${entry.data.title} podcast artwork`}
              width="100"
              height="100"
              class="rounded-3xl"
              loading="lazy"
            />
          </div>
        )
      }
      <Stack spacing={3}>
        {
          entry.data.description && (
            <Typography>{entry.data.description}</Typography>
          )
        }
        {
          entry.data.applePodcastTrackCount !== null && (
            <div class="flex gap-3">
              <Badge label={`${entry.data.applePodcastTrackCount} episodes`} />
            </div>
          )
        }
        <div class="flex flex-wrap items-center gap-3">
          {
            entry.data.appleUrl && (
              <a
                class="block"
                rel="noopener noreferrer"
                target="_blank"
                href={entry.data.appleUrl}
              >
                <span class="sr-only">Listen on Apple Podcasts</span>
                <img
                  class="h-10"
                  height="40"
                  src="/img/apple-podcast.svg"
                  alt=""
                />
              </a>
            )
          }
          {
            entry.data.spotifyUrl && (
              <a
                class="block"
                rel="noopener noreferrer"
                target="_blank"
                href={entry.data.spotifyUrl}
              >
                <span class="sr-only">Listen on Spotify</span>
                <img
                  class="h-10 p-1.5 border border-line-neutral--muted rounded-md"
                  height="40"
                  src="/img/spotify.svg"
                  alt=""
                />
              </a>
            )
          }
        </div>
      </Stack>
    </div>
  </Stack>
</article>
