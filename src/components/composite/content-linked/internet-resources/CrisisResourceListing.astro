---
import type { CollectionEntry } from "astro:content";

import {
  contactTypeIconMap,
  formatAvailability,
  getContactHref,
  getContactLabel,
} from "@ui/utils/content/crisisResource";

import { gapMap, marginTopMap } from "@styles/utils/spacing";
import { textColorMap } from "@styles/utils/color";
import { textPresetClassMap } from "@styles/utils/typography";

import Badge from "@ui/base/Badge.astro";
import Icon from "@ui/base/Icon.astro";
import LinkComp from "@ui/base/Link.astro";
import PortableTextContentBlock from "@ui/base/PortableTextContentBlock.astro";
import SanityImage from "@ui/base/SanityImage.astro";
import Typography from "@ui/base/Typography.astro";

interface Props {
  entry: CollectionEntry<"crisisResources">;
}
const { entry } = Astro.props;

const hasSpanish = entry.data.languages?.includes("Spanish");
const contactMethods = entry.data.contactMethods ?? [];
const logo = entry.data.logo
  ? { image: entry.data.logo, altText: `${entry.data.title} logo` }
  : null;
---

<article id={`resource--${entry.id}`} data-resource-type={entry.collection}>
  <header class="flex flex-col-reverse space-y-reverse space-y-1.5 mb-3">
    <div class="flex items-center gap-3">
      <div>
        <LinkComp external variant="title-4" to={entry.data.resourceUrl ?? ""}>
          <h4 id={entry.id} class="inline m-0" set:text={entry.data.title} />
          <span class="inline-block">
            <Icon
              size={2}
              colorVariant="primary"
              getIcon={(icons) => icons.arrowTopRightOnSquare}
            />
          </span>
        </LinkComp>
      </div>
    </div>
  </header>
  <div class="flex gap-6">
    <div class="shrink">
      {
        entry.data.description && (
          <PortableTextContentBlock portableText={entry.data.description} />
        )
      }
      {
        contactMethods.length > 0 && (
          <ul
            class:list={[
              "flex flex-col",
              gapMap[2],
              marginTopMap[3],
              "list-none p-0",
            ]}
          >
            {contactMethods.map((method) => {
              const href = getContactHref(method);
              const label = getContactLabel(method);
              const iconKey = contactTypeIconMap[method.contactType];
              const availabilities = method.availabilities ?? [];

              return (
                <li class="flex items-start gap-2">
                  <span class="mt-0.5 shrink-0">
                    <Icon
                      size={2}
                      colorVariant="primary"
                      getIcon={(icons) => icons[iconKey]}
                    />
                  </span>
                  <div>
                    {href ? (
                      <a
                        href={href}
                        class:list={[
                          "underline",
                          "text-onSurface-primary--prominent",
                          textPresetClassMap["body-1"],
                        ]}
                        {...(method.contactType === "liveChat" ||
                        method.contactType === "contactForm"
                          ? { target: "_blank", rel: "noopener noreferrer" }
                          : {})}
                      >
                        {label}
                      </a>
                    ) : (
                      <Typography as="span">{label}</Typography>
                    )}
                    {availabilities.length > 0 && (
                      <div
                        class:list={[
                          textColorMap.warmNeutral.default,
                          textPresetClassMap["subtitle-1"],
                        ]}
                      >
                        {availabilities.map((avail) => {
                          const formatted = formatAvailability(avail);
                          return formatted ? <div>{formatted}</div> : null;
                        })}
                      </div>
                    )}
                  </div>
                </li>
              );
            })}
          </ul>
        )
      }
      {
        hasSpanish && (
          <div class:list={["flex", gapMap[2], marginTopMap[3]]}>
            <Badge label="Available in Spanish" />
          </div>
        )
      }
    </div>
    {
      logo && (
        <div class="hidden md:flex md:max-w-62.5 self-center">
          <SanityImage
            image={logo}
            maxWidth={250}
            objectFit="contain"
            useFallback={false}
            aspect="none"
          />
        </div>
      )
    }
  </div>
</article>
