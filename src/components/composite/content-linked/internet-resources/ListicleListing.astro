---
import { getEntry, type CollectionEntry } from "astro:content";

import { collectionKeyToResourceTypeMap } from "@content/collections";
import type { ListOf } from "@content/model/listicle";

import { resourceTypeIconConfigMap } from "@ui/utils/icon";
import { getSourceFromResourceUrl } from "@ui/utils/content/content";
import { getResourceFilterAttrs } from "@ui/utils/content/resourceFilterAttrs";
import { getLocaleDateStringFromIsoString } from "@ui/utils/date";
import { type Link, isLink } from "@ui/utils/link";

import { gapMap, marginTopMap } from "@styles/utils/spacing";

import Badge from "@ui/base/Badge.astro";
import Icon from "@ui/base/Icon.astro";
import LinkComp from "@ui/base/Link.astro";
import Typography from "@ui/base/Typography.astro";

interface Props {
  entry: CollectionEntry<"listicles">;
}

const { entry } = Astro.props;

const listOfLabels: Record<ListOf, string> = {
  app: "List of Apps",
  article: "List of Articles",
  blog: "List of Blogs",
  book: "List of Books",
  community: "List of Communities",
  course: "List of Courses",
  crisisResource: "List of Crisis Resources",
  forum: "List of Forums",
  peerSupport: "List of Peer Support Resources",
  podcast: "List of Podcasts",
  story: "List of Stories",
  supportGroup: "List of Support Groups",
  therapyResource: "List of Therapy Resources",
  video: "List of Videos",
  externalOrg: "List of Organizations",
  mixed: "Mixed list",
};

const lastReviewedDate = getLocaleDateStringFromIsoString(entry.data.updatedAt);

let source: Link | null = null;
if (entry.data.sourceOrgId) {
  const sourceWebsiteEntry = await getEntry(entry.data.sourceOrgId);
  source = {
    label: sourceWebsiteEntry.data.title,
    url: sourceWebsiteEntry.data.resourceUrl,
  };
}

const processedSource =
  source ?? getSourceFromResourceUrl(entry.data.resourceUrl);

const resourceType = collectionKeyToResourceTypeMap[entry.collection];
const iconConfig = resourceTypeIconConfigMap[resourceType];

const isFacebookPage = entry.data.resourceUrl.includes("facebook.com");

const filterAttrs = await getResourceFilterAttrs(entry);
---

<article
  {...filterAttrs}
  id={`resource--${entry.id}`}
  data-resource-type={entry.collection}
>
  <header class="flex flex-col space-y-1.5">
    <div class="mb-1.5">
      <LinkComp external variant="title-4" to={entry.data.resourceUrl}>
        <h4 id={entry.id} class="inline m-0" set:text={entry.data.title} />
        <span class="inline-block">
          <Icon
            size={2}
            colorVariant="primary"
            getIcon={(icons) => icons.arrowTopRightOnSquare}
          />
        </span>
      </LinkComp>
    </div>
    <div class:list={["space-y-1.5", "md:flex md:gap-1.5"]}>
      {
        processedSource !== null && (
          <div class:list={["flex gap-1.5 items-center"]}>
            <Icon
              colorVariant={iconConfig.colorVariant}
              getIcon={() => iconConfig.icon}
              size={1}
              display="inline"
            />
            <Typography variant="subtitle-1">
              {"From "}
              {isLink(processedSource) ? (
                <LinkComp
                  external
                  variant="subtitle-1"
                  to={processedSource.url}
                  label={processedSource.label}
                />
              ) : (
                <span>{processedSource}</span>
              )}
              {","}
            </Typography>
          </div>
        )
      }
      {
        lastReviewedDate && (
          <Typography variant="subtitle-1">
            {"last reviewed "}
            <time datetime={entry.data.updatedAt}>{lastReviewedDate}</time>
          </Typography>
        )
      }
    </div>
  </header>
  <Typography>
    {entry.data.description}
  </Typography>
  <div class:list={["flex flex-wrap", gapMap[2], marginTopMap[3]]}>
    <Badge label={listOfLabels[entry.data.listOf]} />
    {entry.data.paywalled && <Badge label="Payment or Subscription Required" />}
    {
      isFacebookPage && (
        <Badge label="Facebook Account Required" colorVariant="primary" />
      )
    }
    {
      entry.data.registrationRequired && !isFacebookPage && (
        <Badge label="Registration Required" />
      )
    }
  </div>
</article>
