---
import {
  internetResourceCollectionKeys,
  type InternetResourceCollectionKey,
  type InternetResourceEntries,
} from "@content/collections";

import Stack from "@ui/base/Stack.astro";
import Container from "@ui/base/Container.astro";
import ResourceListingRenderer from "@ui/composite/content-linked/internet-resources/ResourceListingRenderer.astro";

import Button from "@ui/base/Button.astro";
import ContentSurface from "@ui/base/ContentSurface.astro";
import FilterButton from "@ui/base/FilterButton.astro";
import Spacer from "@ui/base/Spacer.astro";
import Typography from "@ui/base/Typography.astro";
import InternetResourceListingRenderer from "@ui/composite/content-linked/internet-resources/InternetResourceListingRenderer.astro";
import JumpLinks from "./JumpLinks.astro";
import { kebabCase, startCase } from "lodash";
import type { CollectionEntry } from "astro:content";
import { getResourceIndex } from "@content/utils/resourceIndex";
import {
  TAXONOMY_FILTER_CONFIGS,
  type TaxonomyFilterKey,
  type TaxonomyPageKey,
} from "@content/utils/taxonomy";
import { textColorMap } from "@styles/utils/color";

interface FilterOption {
  value: string;
  label: string;
}

interface FilterGroup {
  key: TaxonomyFilterKey | "mediaType" | "audienceRole" | "supportedGriever";
  label: string;
  options: Array<FilterOption>;
}

const ENUM_FILTER_CONFIGS = [
  { key: "audienceRole" as const, label: "Audience" },
  { key: "supportedGriever" as const, label: "Supporting" },
];

interface Props {
  collection?: TaxonomyPageKey;
  recommendedResources: Array<CollectionEntry<InternetResourceCollectionKey>>;
  mainResources: InternetResourceEntries;
}

const { collection, recommendedResources, mainResources } = Astro.props;

const jumpResourceTypes = Object.keys(
  mainResources,
) as Array<InternetResourceCollectionKey>;

const index = await getResourceIndex();

const displayedResources: Array<
  CollectionEntry<InternetResourceCollectionKey>
> = [...recommendedResources, ...Object.values(mainResources).flat()];

const filterGroups: Array<FilterGroup> = [];

for (const config of TAXONOMY_FILTER_CONFIGS) {
  if (collection && config.key === collection) {
    continue;
  }

  const referencedIds = new Set<string>();
  for (const resource of displayedResources) {
    if (!(config.key in resource.data)) {
      continue;
    }
    const refs = (
      resource.data as unknown as Record<string, Array<{ id: string }>>
    )[config.key];
    for (const ref of refs) {
      referencedIds.add(ref.id);
    }
  }
  if (referencedIds.size === 0) {
    continue;
  }

  const options: Array<FilterOption> = [];
  for (const id of referencedIds) {
    const taxonomyEntry = index.taxonomyEntriesById.get(id);
    if (!taxonomyEntry) {
      continue;
    }
    options.push({
      value: taxonomyEntry.data.slug,
      label: taxonomyEntry.data.title,
    });
  }
  if (options.length === 0) {
    continue;
  }
  filterGroups.push({ key: config.key, label: config.label, options });
}

const presentCollectionKeys = new Set(
  displayedResources.map((r) => r.collection),
);

for (const config of ENUM_FILTER_CONFIGS) {
  const present = new Set<string>();
  for (const resource of displayedResources) {
    const values = (
      resource.data as unknown as Record<string, Array<string> | null>
    )[config.key];
    if (!values) {
      continue;
    }
    for (const v of values) {
      present.add(v);
    }
  }
  if (present.size === 0) {
    continue;
  }
  filterGroups.push({
    key: config.key,
    label: config.label,
    options: [...present].map((v) => ({ value: v, label: startCase(v) })),
  });
}

const mediaTypeOptions: Array<FilterOption> = [];
for (const collectionKey of internetResourceCollectionKeys) {
  if (!presentCollectionKeys.has(collectionKey)) {
    continue;
  }
  mediaTypeOptions.push({
    value: kebabCase(collectionKey),
    label: startCase(collectionKey),
  });
}
if (mediaTypeOptions.length > 0) {
  filterGroups.push({
    key: "mediaType",
    label: "Media Type",
    options: mediaTypeOptions,
  });
}

const CORE_FILTER_KEYS = new Set<FilterGroup["key"]>([
  "causesOfDeath",
  "lossRelationships",
  "themes",
  "demographics",
]);

const coreGroups = filterGroups.filter((g) => CORE_FILTER_KEYS.has(g.key));
const extraGroups = filterGroups.filter((g) => !CORE_FILTER_KEYS.has(g.key));

// If there are no core groups (e.g. a taxonomy detail page whose own
// taxonomy is one of the core four and gets excluded), promote extras
// to render inline without the Show More toggle — otherwise the panel
// would have nothing visible until the user opens it.
const primaryGroups = coreGroups.length > 0 ? coreGroups : extraGroups;
const togglableExtras = coreGroups.length > 0 ? extraGroups : [];

const clearButtonClasses = [
  "bg-contentSurface-neutral--default hover:bg-contentSurface-neutral--prominent",
  "border border-line-neutral--default",
  "hover:border-line-neutral--prominent",
  "text-sm",
  "font-sans-b",
  "block",
  " px-4",
  "cursor-pointer",
  "rounded-sm",
  "transition-colors duration-300",
  textColorMap.warmNeutral.default,
];
---

<resource-filter-controller
  data-filter-panel-active="false"
  data-extras-visible="false"
>
  <Spacer marginBottom={5}>
    {/* Filter Resources */}
    {
      filterGroups.length > 0 && (
        <Spacer marginBottom={4}>
          <ContentSurface prominence="muted" paddingY={4} paddingX={4}>
            <Stack spacing={4}>
              <div class="flex items-start justify-between gap-3">
                <Stack>
                  <Typography
                    as="h2"
                    colorVariant="warmNeutral"
                    variant="title-3"
                    set:text="Filter Resources"
                  />
                  <Typography
                    colorVariant="warmNeutral"
                    set:text="We understand that searching for the right resources can be overwhelming. Use the filter buttons to include only the resources relevant to you."
                  />
                </Stack>
                <button
                  type="button"
                  data-action="clear-all"
                  class:list={["shrink-0 text-sm", ...clearButtonClasses]}
                >
                  Clear all
                </button>
              </div>

              {primaryGroups.map((group) => {
                const groupKey = kebabCase(group.key);
                return (
                  <Stack
                    spacing={2}
                    data-filter-group-key={groupKey}
                    data-filter-group-active="false"
                  >
                    <div class="flex items-center gap-3">
                      <Typography
                        variant="title-5"
                        colorVariant="warmNeutral"
                        set:text={group.label}
                      />
                      <button
                        type="button"
                        data-action="clear-group"
                        data-filter-group-key={groupKey}
                        class="text-sm underline"
                      >
                        Clear
                      </button>
                    </div>
                    <div class="flex flex-wrap gap-2">
                      {group.options.map((option) => (
                        <FilterButton
                          label={option.label}
                          data-filter-key={groupKey}
                          data-filter-value={option.value}
                          data-filter-active="false"
                        />
                      ))}
                    </div>
                  </Stack>
                );
              })}

              {togglableExtras.length > 0 && (
                <>
                  <div data-extra-filters>
                    <Stack spacing={3}>
                      {togglableExtras.map((group) => {
                        const groupKey = kebabCase(group.key);
                        return (
                          <Stack
                            spacing={2}
                            data-filter-group-key={groupKey}
                            data-filter-group-active="false"
                          >
                            <div class="flex items-center gap-3">
                              <Typography
                                variant="title-5"
                                colorVariant="warmNeutral"
                                set:text={group.label}
                              />
                              <button
                                type="button"
                                data-action="clear-group"
                                data-filter-group-key={groupKey}
                                class:list={[
                                  "bg-contentSurface-neutral--default hover:bg-contentSurface-neutral--prominent",
                                  "border border-line-neutral--default",
                                  "hover:border-line-neutral--prominent",
                                  "text-sm",
                                  "font-sans-b",
                                  "block",
                                  " px-4",
                                  "cursor-pointer",
                                  "rounded-sm",
                                  "transition-colors duration-300",
                                  textColorMap.warmNeutral.default,
                                ]}
                              >
                                Clear
                              </button>
                            </div>
                            <div class="flex flex-wrap gap-2">
                              {group.options.map((option) => (
                                <FilterButton
                                  label={option.label}
                                  data-filter-key={groupKey}
                                  data-filter-value={option.value}
                                  data-filter-active="false"
                                />
                              ))}
                            </div>
                          </Stack>
                        );
                      })}
                    </Stack>
                  </div>
                  <button
                    type="button"
                    data-action="toggle-extras"
                    class:list={["self-start text-sm", ...clearButtonClasses]}
                  >
                    <span
                      data-toggle-show
                      set:text={`Show more filter options`}
                    />
                    <span data-toggle-hide>Show fewer filter options</span>
                  </button>
                </>
              )}
            </Stack>
          </ContentSurface>
        </Spacer>
      )
    }
    <div
      class:list={[
        "md:grid md:grid-cols-[1fr_auto] md:gap-6 lg:grid-cols-[1fr_auto_minmax(150px,1fr)] lg:gap-12",
      ]}
    >
      {
        jumpResourceTypes.length > 0 && (
          <>
            <nav
              class="hidden md:block md:order-last"
              data-jump-nav
              aria-label="Jump to resource type"
            >
              <div class="md:sticky md:top-40 md:mt-12">
                <JumpLinks resourceTypes={jumpResourceTypes} />
              </div>
            </nav>
            <div class="md:hidden fixed bottom-4 right-4 z-10" data-mobile-jump>
              <Button
                as="button"
                type="button"
                data-mobile-jump-btn
                label="Jump To"
                textVariant="button-2"
                colorVariant="neutral"
                styleVariant="outlined"
              />
              <div
                data-mobile-jump-panel
                hidden
                class="mt-2 p-3 bg-contentSurface-neutral--muted border border-line-neutral--default rounded-lg shadow-lg"
              >
                <div class="flex justify-between gap-3">
                  <JumpLinks resourceTypes={jumpResourceTypes} />
                  <button
                    type="button"
                    data-mobile-jump-close
                    aria-label="Close jump menu"
                    class="self-start text-onSurface-coolNeutral--muted hover:text-onSurface-coolNeutral--default"
                  >
                    ✕
                  </button>
                </div>
              </div>
            </div>
            <div class="hidden lg:block" />
          </>
        )
      }
      <Container>
        {
          recommendedResources.length > 0 && (
            <div data-filter-section>
              <Spacer marginBottom={6}>
                <ContentSurface
                  prominence="muted"
                  paddingY={4}
                  paddingX={4}
                  variant="primary"
                >
                  <Stack spacing={4} as="section">
                    <Typography
                      as="h2"
                      variant="title-3"
                      set:text="Recommended Resources"
                    />
                    {recommendedResources.map((resource) => (
                      <div
                        data-resource-item
                        class:list={[
                          "not-last:pb-6",
                          "not-last:border-b border-b-line-coolNeutral--default",
                        ]}
                      >
                        <InternetResourceListingRenderer entry={resource} />
                      </div>
                    ))}
                  </Stack>
                </ContentSurface>
              </Spacer>
            </div>
          )
        }
        {
          Object.keys(mainResources).length > 0 && (
            <ResourceListingRenderer internetResources={mainResources} />
          )
        }
      </Container>
    </div>
  </Spacer>
</resource-filter-controller>

<style>
  resource-filter-controller[data-filter-panel-active="false"]
    [data-action="clear-all"] {
    display: none;
  }
  resource-filter-controller
    [data-filter-group-key][data-filter-group-active="false"]
    [data-action="clear-group"] {
    display: none;
  }

  /* Show More / Show Fewer disclosure for the non-core filter groups. */
  resource-filter-controller[data-extras-visible="false"] [data-extra-filters] {
    display: none;
  }
  resource-filter-controller[data-extras-visible="true"] [data-toggle-show],
  resource-filter-controller[data-extras-visible="false"] [data-toggle-hide] {
    display: none;
  }

  /*
   * Filter button palette + state styling.
   *
   * Each filter group wrapper sets a small set of CSS custom properties
   * (the "palette" for its taxonomy color). Buttons inside inherit them
   * and switch between three prominence levels based on the group's
   * data-filter-group-active and the button's own data-filter-active.
   *
   * We deliberately bypass the design-system colorVariant/prominence
   * class-map ceremony here and consume the underlying CSS custom
   * properties directly, because the prominence has to swap at runtime
   * based on DOM state attributes — something Tailwind utility classes
   * baked at build time can't express.
   */

  /* Neutral fallback first so per-taxonomy rules below override on equal
     specificity. */
  resource-filter-controller [data-filter-group-key] {
    --fb-bg-default: var(--color-contentSurface-neutral--default);
    --fb-bg-prominent: var(--color-contentSurface-neutral--prominent);
    --fb-bg-muted: var(--color-contentSurface-neutral--muted);
    --fb-border-default: var(--color-line-neutral--default);
    --fb-border-prominent: var(--color-line-neutral--prominent);
    --fb-border-muted: var(--color-line-neutral--muted);
    --fb-text: var(--color-onSurface-warmNeutral--default);
  }

  resource-filter-controller [data-filter-group-key="loss-relationships"] {
    --fb-bg-default: var(--color-contentSurface-primary--default);
    --fb-bg-prominent: var(--color-contentSurface-primary--prominent);
    --fb-bg-muted: var(--color-contentSurface-primary--muted);
    --fb-border-default: var(--color-line-primary--default);
    --fb-border-prominent: var(--color-line-primary--prominent);
    --fb-border-muted: var(--color-line-primary--muted);
    --fb-text: var(--color-onSurface-primary--default);
  }

  resource-filter-controller [data-filter-group-key="causes-of-death"] {
    --fb-bg-default: var(--color-contentSurface-secondary--default);
    --fb-bg-prominent: var(--color-contentSurface-secondary--prominent);
    --fb-bg-muted: var(--color-contentSurface-secondary--muted);
    --fb-border-default: var(--color-line-secondary--default);
    --fb-border-prominent: var(--color-line-secondary--prominent);
    --fb-border-muted: var(--color-line-secondary--muted);
    --fb-text: var(--color-onSurface-secondary--default);
  }

  resource-filter-controller [data-filter-group-key="themes"] {
    --fb-bg-default: var(--color-contentSurface-tertiary--default);
    --fb-bg-prominent: var(--color-contentSurface-tertiary--prominent);
    --fb-bg-muted: var(--color-contentSurface-tertiary--muted);
    --fb-border-default: var(--color-line-tertiary--default);
    --fb-border-prominent: var(--color-line-tertiary--prominent);
    --fb-border-muted: var(--color-line-tertiary--muted);
    --fb-text: var(--color-onSurface-tertiary--default);
  }

  /* Secondary taxonomy palettes — consume primitive --token-color-*
     values directly. These don't earn a place in the global semantic
     token layer because they're only used by the filter buttons. Text
     reuses --color-onSurface-primary--default (a dark blue) since every
     palette here is a light tint and the dark-blue text contrasts well
     across all of them. */

  resource-filter-controller [data-filter-group-key="demographics"] {
    --fb-bg-default: var(--token-color-purple-95);
    --fb-bg-prominent: var(--token-color-purple-87);
    --fb-bg-muted: var(--token-color-purple-97);
    --fb-border-default: var(--token-color-purple-87);
    --fb-border-prominent: var(--token-color-purple-80);
    --fb-border-muted: var(--token-color-purple-92);
    --fb-text: var(--color-onSurface-primary--default);
  }

  resource-filter-controller [data-filter-group-key="grief-phases"] {
    --fb-bg-default: var(--token-color-yellow-95);
    --fb-bg-prominent: var(--token-color-yellow-87);
    --fb-bg-muted: var(--token-color-yellow-97);
    --fb-border-default: var(--token-color-yellow-87);
    --fb-border-prominent: var(--token-color-yellow-80);
    --fb-border-muted: var(--token-color-yellow-92);
    --fb-text: var(--color-onSurface-primary--default);
  }

  resource-filter-controller [data-filter-group-key="grief-types"] {
    --fb-bg-default: var(--token-color-orange-95);
    --fb-bg-prominent: var(--token-color-orange-87);
    --fb-bg-muted: var(--token-color-orange-97);
    --fb-border-default: var(--token-color-orange-87);
    --fb-border-prominent: var(--token-color-orange-80);
    --fb-border-muted: var(--token-color-orange-92);
    --fb-text: var(--color-onSurface-primary--default);
  }

  resource-filter-controller [data-filter-group-key="content-functions"] {
    --fb-bg-default: var(--token-color-indigo-95);
    --fb-bg-prominent: var(--token-color-indigo-87);
    --fb-bg-muted: var(--token-color-indigo-97);
    --fb-border-default: var(--token-color-indigo-87);
    --fb-border-prominent: var(--token-color-indigo-80);
    --fb-border-muted: var(--token-color-indigo-92);
    --fb-text: var(--color-onSurface-primary--default);
  }

  resource-filter-controller [data-filter-group-key="emotional-states"] {
    --fb-bg-default: var(--token-color-lime-95);
    --fb-bg-prominent: var(--token-color-lime-87);
    --fb-bg-muted: var(--token-color-lime-97);
    --fb-border-default: var(--token-color-lime-87);
    --fb-border-prominent: var(--token-color-lime-80);
    --fb-border-muted: var(--token-color-lime-92);
    --fb-text: var(--color-onSurface-primary--default);
  }

  /* Text color is constant per palette — prominence is carried by
     background and border only, so inactive buttons don't read as
     disabled. */
  resource-filter-controller
    [data-filter-group-key]
    button[data-filter-active] {
    color: var(--fb-text);
  }

  /* No filter active in this group → mid prominence */
  resource-filter-controller
    [data-filter-group-active="false"]
    button[data-filter-active] {
    background-color: var(--fb-bg-default);
    border-color: var(--fb-border-default);
  }

  /* Group has active filters, this button is one of them → prominent */
  resource-filter-controller
    [data-filter-group-active="true"]
    button[data-filter-active="true"] {
    background-color: var(--fb-bg-prominent);
    border-color: var(--fb-border-prominent);
  }

  /* Group has active filters, this button is not one of them → muted */
  resource-filter-controller
    [data-filter-group-active="true"]
    button[data-filter-active="false"] {
    background-color: var(--fb-bg-muted);
    border-color: var(--fb-border-muted);
  }

  /* Hover: bump non-active buttons up one prominence level. */
  resource-filter-controller
    [data-filter-group-active="false"]
    button[data-filter-active]:hover {
    background-color: var(--fb-bg-prominent);
    border-color: var(--fb-border-prominent);
  }

  resource-filter-controller
    [data-filter-group-active="true"]
    button[data-filter-active="false"]:hover {
    background-color: var(--fb-bg-default);
    border-color: var(--fb-border-default);
  }
</style>

<script>
  type FilterMap = Map<string, Set<string>>;

  class ResourceFilterController extends HTMLElement {
    connectedCallback() {
      this.addEventListener("click", this.handleClick);
      this.autoExpandIfActiveExtras();
      this.applyFromUrl();
    }

    autoExpandIfActiveExtras() {
      const active = this.getActiveFilters();
      const extraKeys = new Set(
        Array.from(
          this.querySelectorAll<HTMLElement>(
            "[data-extra-filters] [data-filter-group-key]",
          ),
        ).map((el) => el.dataset.filterGroupKey),
      );
      const hasActiveExtra = [...active.keys()].some((k) => extraKeys.has(k));
      if (hasActiveExtra) {
        this.dataset.extrasVisible = "true";
      }
    }

    disconnectedCallback() {
      this.removeEventListener("click", this.handleClick);
    }

    handleClick = (event: Event) => {
      const target = event.target as Element | null;
      if (!target) {
        return;
      }

      const filterBtn = target.closest<HTMLElement>(
        "[data-filter-key][data-filter-value]",
      );
      if (filterBtn) {
        const key = filterBtn.dataset.filterKey;
        const value = filterBtn.dataset.filterValue;
        if (key && value) {
          this.toggleFilter(key, value);
        }
        return;
      }

      const clearGroup = target.closest<HTMLElement>(
        '[data-action="clear-group"]',
      );
      if (clearGroup) {
        const key = clearGroup.dataset.filterGroupKey;
        if (key) {
          this.clearGroup(key);
        }
        return;
      }

      const clearAll = target.closest<HTMLElement>('[data-action="clear-all"]');
      if (clearAll) {
        this.clearAll();
        return;
      }

      const toggleExtras = target.closest<HTMLElement>(
        '[data-action="toggle-extras"]',
      );
      if (toggleExtras) {
        this.dataset.extrasVisible =
          this.dataset.extrasVisible === "true" ? "false" : "true";
        return;
      }

      const mobileToggle = target.closest<HTMLElement>(
        "[data-mobile-jump-btn], [data-mobile-jump-close]",
      );
      if (mobileToggle) {
        this.toggleMobilePanel();
        return;
      }

      const backToTop = target.closest<HTMLElement>("[data-back-to-top]");
      if (backToTop) {
        event.preventDefault();
        window.scrollTo({ top: 0, behavior: "smooth" });
        if (backToTop.closest("[data-mobile-jump-panel]")) {
          this.toggleMobilePanel();
        }
        return;
      }

      const jumpLink = target.closest<HTMLElement>("[data-jump-link]");
      if (jumpLink && jumpLink.closest("[data-mobile-jump-panel]")) {
        this.toggleMobilePanel();
        return;
      }
    };

    getActiveFilters(): FilterMap {
      const params = new URLSearchParams(window.location.search);
      const map: FilterMap = new Map();
      for (const [k, v] of params) {
        const set = new Set(v.split(",").filter(Boolean));
        if (set.size > 0) {
          map.set(k, set);
        }
      }
      return map;
    }

    setActiveFilters(map: FilterMap) {
      const parts: string[] = [];
      for (const [k, set] of map) {
        if (set.size === 0) {
          continue;
        }
        const values = [...set].map((v) => encodeURIComponent(v)).join(",");
        parts.push(`${encodeURIComponent(k)}=${values}`);
      }
      const qs = parts.join("&");
      const newUrl = qs
        ? `${window.location.pathname}?${qs}`
        : window.location.pathname;
      history.replaceState(null, "", newUrl);
      this.applyFromUrl();
    }

    toggleFilter(group: string, value: string) {
      const map = this.getActiveFilters();
      const set = map.get(group) ?? new Set<string>();
      if (set.has(value)) {
        set.delete(value);
      } else {
        set.add(value);
      }
      if (set.size > 0) {
        map.set(group, set);
      } else {
        map.delete(group);
      }
      this.setActiveFilters(map);
    }

    clearGroup(group: string) {
      const map = this.getActiveFilters();
      map.delete(group);
      this.setActiveFilters(map);
    }

    clearAll() {
      this.setActiveFilters(new Map());
    }

    toggleMobilePanel() {
      const panel = this.querySelector<HTMLElement>("[data-mobile-jump-panel]");
      const btn = this.querySelector<HTMLElement>("[data-mobile-jump-btn]");
      panel?.toggleAttribute("hidden");
      btn?.toggleAttribute("hidden");
    }

    applyFromUrl() {
      const active = this.getActiveFilters();

      this.querySelectorAll<HTMLElement>(
        "[data-filter-key][data-filter-value]",
      ).forEach((btn) => {
        const key = btn.dataset.filterKey;
        const value = btn.dataset.filterValue;
        const isActive = !!(key && value && active.get(key)?.has(value));
        btn.dataset.filterActive = isActive ? "true" : "false";
      });

      this.querySelectorAll<HTMLElement>("[data-filter-group-key]").forEach(
        (group) => {
          const key = group.dataset.filterGroupKey;
          const isActive = !!(key && (active.get(key)?.size ?? 0) > 0);
          group.dataset.filterGroupActive = isActive ? "true" : "false";
        },
      );

      const anyActive = [...active.values()].some((s) => s.size > 0);
      this.dataset.filterPanelActive = anyActive ? "true" : "false";

      this.querySelectorAll<HTMLElement>("[data-resource-media-type]").forEach(
        (res) => {
          const matches = this.resourceMatches(res, active);
          const target =
            res.closest<HTMLElement>("[data-resource-item]") ?? res;
          target.hidden = !matches;
        },
      );

      this.querySelectorAll<HTMLElement>(
        "[data-resource-section], [data-filter-section]",
      ).forEach((section) => {
        const items = section.querySelectorAll<HTMLElement>(
          "[data-resource-media-type]",
        );
        if (items.length === 0) {
          return;
        }
        const anyVisible = Array.from(items).some((r) => {
          const target = r.closest<HTMLElement>("[data-resource-item]") ?? r;
          return !target.hidden;
        });
        section.hidden = !anyVisible;
      });

      this.querySelectorAll<HTMLElement>("[data-jump-link]").forEach((link) => {
        const type = link.dataset.jumpLink;
        if (!type) {
          return;
        }
        const section = this.querySelector<HTMLElement>(
          `[data-resource-section="${type}"]`,
        );
        if (section?.hidden) {
          link.setAttribute("data-filtered", "");
        } else {
          link.removeAttribute("data-filtered");
        }
      });
    }

    resourceMatches(el: HTMLElement, active: FilterMap): boolean {
      for (const [groupKey, activeSet] of active) {
        if (activeSet.size === 0) {
          continue;
        }
        const attr = el.getAttribute(`data-resource-${groupKey}`) ?? "";
        const values = attr.split(",").filter(Boolean);
        if (!values.some((v) => activeSet.has(v))) {
          return false;
        }
      }
      return true;
    }
  }

  customElements.define("resource-filter-controller", ResourceFilterController);
</script>
