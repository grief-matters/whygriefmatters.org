---
import Icon from "@ui/base/Icon.astro";
import Typography from "@ui/base/Typography.astro";

interface Props {
  emptyStateMessage?: string;
  noResultsMessage?: string;
}

const {
  emptyStateMessage = "Please enter a search term, or apply some filters to see resources.",
  noResultsMessage = "No resources match your search.",
} = Astro.props;
---

<resource-search-controller>
  <div class="space-y-6">
    <div
      class:list={[
        "w-full px-4 py-3 border rounded-full border-line-primary--muted",
        "focus-within:border-line-primary--default transition-colors",
        "flex items-center gap-2 bg-contentSurface-neutral--default",
      ]}
    >
      <Icon
        getIcon={(icons) => icons.magnifyingGlass}
        colorVariant="primary"
        display="inline"
      />
      <input
        type="search"
        data-search-input
        autocomplete="off"
        placeholder="Search resources..."
        aria-label="Search resources"
        class:list={[
          "flex-1 min-w-0 bg-transparent",
          "font-serif text-onSurface-coolNeutral--default",
          "placeholder:text-onSurface-coolNeutral--muted",
          "focus:outline-none",
        ]}
      />
    </div>

    <slot name="filter-panel" />

    <div data-state-initial class="text-center py-8">
      <slot name="empty-initial">
        <Typography colorVariant="coolNeutral" textAlign="center"
          >{emptyStateMessage}</Typography
        >
      </slot>
    </div>

    <div data-state-no-results hidden class="text-center py-8">
      <Typography colorVariant="coolNeutral" textAlign="center"
        >{noResultsMessage}</Typography
      >
    </div>

    <div data-search-results-list class="flex flex-col">
      <slot name="results" />
    </div>

    <div class="flex justify-center">
      <button
        type="button"
        data-search-show-more
        hidden
        class:list={[
          "px-4 py-2 rounded-full border border-line-primary--default",
          "text-onSurface-primary--default font-sans-b text-sm",
          "hover:bg-contentSurface-primary--muted cursor-pointer",
          "transition-colors",
        ]}
      >
        Show more results
      </button>
    </div>
  </div>
</resource-search-controller>

<script>
  import debounce from "lodash/debounce";
  import type MiniSearchType from "minisearch";

  type FilterMap = Map<string, Set<string>>;
  type SearchDoc = {
    id: string;
    title: string;
    searchAliases: string[];
    description: string;
    source: string;
  };

  class ResourceSearchController extends HTMLElement {
    private mini: MiniSearchType<SearchDoc> | null = null;
    private miniLoading: Promise<void> | null = null;
    private pageSize = 10;
    private query = "";
    private panel: HTMLElement | null = null;
    private input: HTMLInputElement | null = null;
    private cards: HTMLElement[] = [];
    private debouncedOnInput = debounce((v: string) => {
      this.onQueryChanged(v);
    }, 300);

    connectedCallback() {
      this.panel = this.querySelector<HTMLElement>("[data-filter-panel]");
      this.input = this.querySelector<HTMLInputElement>("[data-search-input]");
      this.cards = Array.from(
        this.querySelectorAll<HTMLElement>("[data-search-card]"),
      );

      this.addEventListener("click", this.handleClick);
      this.input?.addEventListener("input", this.handleInput);
      this.input?.addEventListener("focus", this.preloadMini, { once: true });

      const params = new URLSearchParams(window.location.search);
      this.query = params.get("q") ?? "";
      if (this.input) {
        this.input.value = this.query;
      }

      this.autoExpandIfActiveExtras();
      void this.applyFromUrl();
    }

    disconnectedCallback() {
      this.removeEventListener("click", this.handleClick);
      this.input?.removeEventListener("input", this.handleInput);
      this.debouncedOnInput.cancel();
    }

    private autoExpandIfActiveExtras() {
      const active = this.getActiveFilters();
      if (!this.panel) {
        return;
      }
      const anyActive = [...active.values()].some((s) => s.size > 0);
      if (anyActive && this.panel.dataset.panelCollapsed === "true") {
        this.panel.dataset.panelCollapsed = "false";
      }
      const extraKeys = new Set(
        Array.from(
          this.querySelectorAll<HTMLElement>(
            "[data-extra-filters] [data-filter-group-key]",
          ),
        ).map((el) => el.dataset.filterGroupKey),
      );
      const hasActiveExtra = [...active.keys()].some((k) => extraKeys.has(k));
      if (hasActiveExtra) {
        this.panel.dataset.extrasVisible = "true";
      }
    }

    private handleInput = (e: Event) => {
      const value = (e.target as HTMLInputElement).value;
      this.debouncedOnInput(value);
    };

    private preloadMini = () => {
      void this.ensureMini();
    };

    private async ensureMini(): Promise<void> {
      if (this.mini) {
        return;
      }
      if (this.miniLoading) {
        return this.miniLoading;
      }
      this.miniLoading = (async () => {
        const MiniSearch = (await import("minisearch")).default;
        const indexEl = document.getElementById("search-index");
        const raw = indexEl?.textContent ?? "[]";
        let docs: SearchDoc[] = [];
        try {
          docs = JSON.parse(raw) as SearchDoc[];
        } catch (err) {
          console.error("[search] failed to parse search index", err);
        }
        const mini = new MiniSearch<SearchDoc>({
          fields: ["title", "searchAliases", "description", "source"],
          storeFields: ["id"],
          searchOptions: {
            boost: { title: 3, searchAliases: 2 },
            prefix: true,
            fuzzy: 0.2,
            combineWith: "AND",
          },
        });
        mini.addAll(docs);
        this.mini = mini;
      })();
      return this.miniLoading;
    }

    private handleClick = (event: Event) => {
      const target = event.target as Element | null;
      if (!target) {
        return;
      }

      const filterBtn = target.closest<HTMLElement>(
        "[data-filter-key][data-filter-value]",
      );
      if (filterBtn) {
        const key = filterBtn.dataset.filterKey;
        const value = filterBtn.dataset.filterValue;
        if (key && value) {
          this.toggleFilter(key, value);
        }
        return;
      }

      const clearGroup = target.closest<HTMLElement>(
        '[data-action="clear-group"]',
      );
      if (clearGroup) {
        const key = clearGroup.dataset.filterGroupKey;
        if (key) {
          this.clearGroup(key);
        }
        return;
      }

      const clearAll = target.closest<HTMLElement>('[data-action="clear-all"]');
      if (clearAll) {
        this.clearAll();
        return;
      }

      const toggleExtras = target.closest<HTMLElement>(
        '[data-action="toggle-extras"]',
      );
      if (toggleExtras && this.panel) {
        this.panel.dataset.extrasVisible =
          this.panel.dataset.extrasVisible === "true" ? "false" : "true";
        return;
      }

      const togglePanel = target.closest<HTMLElement>(
        '[data-action="toggle-panel"]',
      );
      if (togglePanel && this.panel) {
        this.panel.dataset.panelCollapsed =
          this.panel.dataset.panelCollapsed === "true" ? "false" : "true";
        return;
      }

      const showMore = target.closest<HTMLElement>("[data-search-show-more]");
      if (showMore) {
        this.pageSize += 10;
        void this.applyFromUrl();
        return;
      }
    };

    private onQueryChanged(value: string) {
      this.query = value;
      this.updateQueryUrl();
      this.pageSize = 10;
      void this.applyFromUrl();
    }

    private updateQueryUrl() {
      const params = new URLSearchParams(window.location.search);
      if (this.query.trim()) {
        params.set("q", this.query);
      } else {
        params.delete("q");
      }
      const qs = params.toString();
      const newUrl = qs
        ? `${window.location.pathname}?${qs}`
        : window.location.pathname;
      history.replaceState(null, "", newUrl);
    }

    private getActiveFilters(): FilterMap {
      const params = new URLSearchParams(window.location.search);
      const map: FilterMap = new Map();
      for (const [k, v] of params) {
        if (k === "q") {
          continue;
        }
        const set = new Set(v.split(",").filter(Boolean));
        if (set.size > 0) {
          map.set(k, set);
        }
      }
      return map;
    }

    private setActiveFilters(map: FilterMap) {
      const params = new URLSearchParams();
      if (this.query.trim()) {
        params.set("q", this.query);
      }
      for (const [k, set] of map) {
        if (set.size === 0) {
          continue;
        }
        params.set(k, [...set].join(","));
      }
      const qs = params.toString();
      const newUrl = qs
        ? `${window.location.pathname}?${qs}`
        : window.location.pathname;
      history.replaceState(null, "", newUrl);
      this.pageSize = 10;
      void this.applyFromUrl();
    }

    private toggleFilter(group: string, value: string) {
      const map = this.getActiveFilters();
      const set = map.get(group) ?? new Set<string>();
      if (set.has(value)) {
        set.delete(value);
      } else {
        set.add(value);
      }
      if (set.size > 0) {
        map.set(group, set);
      } else {
        map.delete(group);
      }
      this.setActiveFilters(map);
    }

    private clearGroup(group: string) {
      const map = this.getActiveFilters();
      map.delete(group);
      this.setActiveFilters(map);
    }

    private clearAll() {
      this.setActiveFilters(new Map());
    }

    private async applyFromUrl(): Promise<void> {
      const active = this.getActiveFilters();

      this.querySelectorAll<HTMLElement>(
        "[data-filter-key][data-filter-value]",
      ).forEach((btn) => {
        const key = btn.dataset.filterKey;
        const value = btn.dataset.filterValue;
        const isActive = !!(key && value && active.get(key)?.has(value));
        btn.dataset.filterActive = isActive ? "true" : "false";
      });

      this.querySelectorAll<HTMLElement>("[data-filter-group-key]").forEach(
        (group) => {
          const key = group.dataset.filterGroupKey;
          const isActive = !!(key && (active.get(key)?.size ?? 0) > 0);
          group.dataset.filterGroupActive = isActive ? "true" : "false";
        },
      );

      const hasFilters = [...active.values()].some((s) => s.size > 0);
      if (this.panel) {
        this.panel.dataset.panelActive = hasFilters ? "true" : "false";
      }

      const hasQuery = this.query.trim().length >= 2;
      const stateInitial = this.querySelector<HTMLElement>(
        "[data-state-initial]",
      );
      const stateNoResults = this.querySelector<HTMLElement>(
        "[data-state-no-results]",
      );
      const showMoreBtn = this.querySelector<HTMLElement>(
        "[data-search-show-more]",
      );

      if (!hasQuery && !hasFilters) {
        if (stateInitial) {
          stateInitial.hidden = false;
        }
        if (stateNoResults) {
          stateNoResults.hidden = true;
        }
        if (showMoreBtn) {
          showMoreBtn.hidden = true;
        }
        for (const card of this.cards) {
          card.hidden = true;
          card.style.order = "0";
        }
        return;
      }

      const filterIds = new Set<string>();
      for (const card of this.cards) {
        const id = card.dataset.resultId;
        if (!id) {
          continue;
        }
        if (this.resourceMatches(card, active)) {
          filterIds.add(id);
        }
      }

      let matchedOrdered: string[];
      if (hasQuery) {
        await this.ensureMini();
        if (!this.mini) {
          matchedOrdered = [];
        } else {
          const results = this.mini.search(this.query);
          const searchIds = results.map((r) => r.id as string);
          matchedOrdered = hasFilters
            ? searchIds.filter((id) => filterIds.has(id))
            : searchIds;
        }
      } else {
        const matched = this.cards.filter((c) => {
          const id = c.dataset.resultId;
          return !!id && filterIds.has(id);
        });
        matched.sort((a, b) => {
          const aT = a.dataset.resourceUpdatedAt ?? "";
          const bT = b.dataset.resourceUpdatedAt ?? "";
          return bT.localeCompare(aT);
        });
        matchedOrdered = matched
          .map((c) => c.dataset.resultId)
          .filter((id): id is string => !!id);
      }

      const rank = new Map<string, number>();
      matchedOrdered.forEach((id, i) => rank.set(id, i));

      for (const card of this.cards) {
        const id = card.dataset.resultId;
        if (!id) {
          continue;
        }
        const r = rank.get(id);
        if (r === undefined || r >= this.pageSize) {
          card.hidden = true;
          card.style.order = "0";
        } else {
          card.hidden = false;
          card.style.order = String(r);
        }
      }

      if (stateInitial) {
        stateInitial.hidden = true;
      }
      if (matchedOrdered.length === 0) {
        if (stateNoResults) {
          stateNoResults.hidden = false;
        }
        if (showMoreBtn) {
          showMoreBtn.hidden = true;
        }
      } else {
        if (stateNoResults) {
          stateNoResults.hidden = true;
        }
        if (showMoreBtn) {
          showMoreBtn.hidden = matchedOrdered.length <= this.pageSize;
        }
      }
    }

    private resourceMatches(el: HTMLElement, active: FilterMap): boolean {
      for (const [groupKey, activeSet] of active) {
        if (activeSet.size === 0) {
          continue;
        }
        const attr = el.getAttribute(`data-resource-${groupKey}`) ?? "";
        const values = attr.split(",").filter(Boolean);
        if (!values.some((v) => activeSet.has(v))) {
          return false;
        }
      }
      return true;
    }
  }

  customElements.define("resource-search-controller", ResourceSearchController);
</script>
