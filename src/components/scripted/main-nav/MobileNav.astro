---
import type { NavTreeNode } from "@ui/utils/navigation-tree";

import BackButton from "@ui/base/BackButton.astro";
import Button from "@ui/base/Button.astro";
import Icon from "@ui/base/Icon.astro";
import LayoutSurface from "@ui/base/LayoutSurface.astro";
import Typography from "@ui/base/Typography.astro";
import TextButton from "@ui/base/TextButton.astro";
import NavTreeLink from "@ui/composite/content-linked/NavTreeLink.astro";

interface Props {
  navTree: NavTreeNode[];
}

const { navTree } = Astro.props;

const basePanelClasses = [
  "absolute inset-0 bg-layoutSurface-neutral--1 flex flex-col",
];
const transitionClasses = [
  "translate-x-full transition-transform duration-300 ease-in-out",
];
const navContainerClasses = ["p-12 space-y-4"];

/**
 * Path-keyed flat lists for each tier. Keys are dotted paths
 * (e.g. "0", "0.2", "0.2.1") so the controller can drill in any depth.
 */
const tier1Items = navTree.map((node, i) => ({
  key: String(i),
  node,
}));

const tier2Sections = tier1Items.flatMap(({ key: tier1Key, node }) => {
  if (node.kind !== "navItemGroup") {
    return [];
  }
  return [
    {
      tier1Key,
      groupLabel: node.label,
      children: node.items.map((child, j) => ({
        key: `${tier1Key}.${j}`,
        node: child,
      })),
    },
  ];
});

const tier3Sections = tier2Sections.flatMap(({ children }) =>
  children.flatMap(({ key: tier2Key, node }) => {
    if (node.kind !== "navItemGroup") {
      return [];
    }
    return [
      {
        tier2Key,
        groupLabel: node.label,
        children: node.items.map((child, j) => ({
          key: `${tier2Key}.${j}`,
          node: child,
        })),
      },
    ];
  }),
);

const tier4Sections = tier3Sections.flatMap(({ children }) =>
  children.flatMap(({ key: tier3Key, node }) => {
    if (node.kind !== "navItemGroup") {
      return [];
    }
    return [
      {
        tier3Key,
        groupLabel: node.label,
        items: node.items,
      },
    ];
  }),
);
---

<mobile-nav-controller>
  <LayoutSurface colorVariant="primaryContrast" colorVariantKey={2}>
    <div class="flex justify-end p-2">
      <button
        data-mobile-trigger
        aria-expanded="false"
        aria-label="Open navigation menu"
        aria-controls="mobile-menu"
        type="button"
        class:list={["bg-contentSurface-primaryContrast--prominent"]}
      >
        <span class="flex items-center gap-1">
          <Typography
            as="span"
            variant="button-1"
            colorVariant="primaryContrast"
            set:text="Menu"
          />
          <Icon
            display="inline"
            getIcon={(icons) => icons.barsThree}
            colorVariant="primaryContrast"
            size={3}
          />
        </span>
      </button>
    </div>
  </LayoutSurface>

  <!-- Mobile overlay -->
  <nav id="mobile-menu" data-mobile-menu hidden class="fixed inset-0 z-50">
    <!-- Tier 1 Panel -->
    <div data-tier1-panel class:list={[...basePanelClasses]}>
      <div class="flex justify-end p-4">
        <Button
          data-mobile-close
          type="button"
          styleVariant="outlined"
          colorVariant="neutral"
          textVariant="button-1"
          label="Close"
        />
      </div>
      <div class:list={navContainerClasses}>
        {
          tier1Items.map(({ key, node }) =>
            node.kind === "navItemGroup" ? (
              <TextButton
                type="button"
                variant="title-3"
                data-mobile-tier1-btn={key}
                label={node.label ?? "(untitled)"}
                class="w-full text-left"
              />
            ) : (
              <NavTreeLink
                node={node}
                variant="title-3"
                colorVariant="primary"
                class="w-full text-left block"
              />
            ),
          )
        }
      </div>
    </div>

    <!-- Tier 2 Panel -->
    <div
      data-tier2-panel
      class:list={[...basePanelClasses, ...transitionClasses]}
    >
      <header class="flex justify-between items-center p-4">
        <BackButton data-mobile-back-to-tier1 />
        <Button
          data-mobile-close
          type="button"
          styleVariant="outlined"
          colorVariant="neutral"
          textVariant="button-1"
          label="Close"
        />
      </header>
      {
        tier2Sections.map(({ tier1Key, groupLabel, children }) => (
          <div
            data-tier2-section={tier1Key}
            hidden
            class:list={navContainerClasses}
          >
            <Typography as="h2" variant="title-3" set:text={groupLabel ?? ""} />
            {children.map(({ key, node }) =>
              node.kind === "navItemGroup" ? (
                <TextButton
                  type="button"
                  variant="title-5"
                  data-mobile-tier2-btn={key}
                  label={node.label ?? "(untitled)"}
                  class="w-full text-left"
                />
              ) : (
                <NavTreeLink
                  node={node}
                  variant="title-5"
                  colorVariant="primary"
                  class="w-full text-left block"
                />
              ),
            )}
          </div>
        ))
      }

      <!-- Tier 3 Panel -->
      <div
        data-tier3-panel
        class:list={[...basePanelClasses, ...transitionClasses]}
      >
        <header class="flex justify-between items-center p-4">
          <BackButton data-mobile-back-to-tier2 />
          <Button
            data-mobile-close
            styleVariant="outlined"
            colorVariant="neutral"
            textVariant="button-1"
            label="Close"
          />
        </header>
        {
          tier3Sections.map(({ tier2Key, groupLabel, children }) => (
            <div
              data-tier3-section={tier2Key}
              hidden
              class:list={navContainerClasses}
            >
              <Typography
                as="h3"
                variant="title-3"
                set:text={groupLabel ?? ""}
              />
              {children.map(({ key, node }) =>
                node.kind === "navItemGroup" ? (
                  <TextButton
                    type="button"
                    variant="title-5"
                    data-mobile-tier3-btn={key}
                    label={node.label ?? "(untitled)"}
                    class="w-full text-left"
                  />
                ) : (
                  <NavTreeLink
                    node={node}
                    variant="title-5"
                    colorVariant="primary"
                    class="w-full text-left block"
                  />
                ),
              )}
            </div>
          ))
        }

        <!-- Tier 4 Panel -->
        <div
          data-tier4-panel
          class:list={[...basePanelClasses, ...transitionClasses]}
        >
          <header class="flex justify-between items-center p-4">
            <BackButton data-mobile-back-to-tier3 />
            <Button
              data-mobile-close
              styleVariant="outlined"
              colorVariant="neutral"
              textVariant="button-1"
              label="Close"
            />
          </header>
          {
            tier4Sections.map(({ tier3Key, groupLabel, items }) => (
              <div
                data-tier4-section={tier3Key}
                hidden
                class:list={navContainerClasses}
              >
                <Typography
                  as="h4"
                  variant="title-3"
                  set:text={groupLabel ?? ""}
                />
                {items.map((node) =>
                  node.kind !== "navItemGroup" ? (
                    <NavTreeLink
                      node={node}
                      variant="title-5"
                      colorVariant="primary"
                      class="w-full text-left block"
                    />
                  ) : (
                    <Typography
                      as="span"
                      variant="title-5"
                      set:text={node.label ?? ""}
                    />
                  ),
                )}
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </nav>

  <script is:inline>
    class MobileNavController extends HTMLElement {
      selectedTier1Key = null;
      selectedTier2Key = null;
      selectedTier3Key = null;

      connectedCallback() {
        this.setupHandlers();
        this.setupKeyboardHandlers();
      }

      setupHandlers() {
        const mobileTrigger = this.querySelector("[data-mobile-trigger]");
        mobileTrigger?.addEventListener("click", () => this.openMenu());

        this.querySelectorAll("[data-mobile-close]").forEach((btn) => {
          btn.addEventListener("click", () => this.closeMenu());
        });

        this.querySelectorAll("[data-mobile-tier1-btn]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const tier1Key = btn.getAttribute("data-mobile-tier1-btn");
            this.showTier2(tier1Key);
          });
        });

        this.querySelectorAll("[data-mobile-tier2-btn]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const tier2Key = btn.getAttribute("data-mobile-tier2-btn");
            this.showTier3(tier2Key);
          });
        });

        this.querySelectorAll("[data-mobile-tier3-btn]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const tier3Key = btn.getAttribute("data-mobile-tier3-btn");
            this.showTier4(tier3Key);
          });
        });

        const backToTier1 = this.querySelector("[data-mobile-back-to-tier1]");
        backToTier1?.addEventListener("click", () => this.hideTier2());

        const backToTier2 = this.querySelector("[data-mobile-back-to-tier2]");
        backToTier2?.addEventListener("click", () => this.hideTier3());

        const backToTier3 = this.querySelector("[data-mobile-back-to-tier3]");
        backToTier3?.addEventListener("click", () => this.hideTier4());
      }

      openMenu() {
        const menu = this.querySelector("[data-mobile-menu]");
        const trigger = this.querySelector("[data-mobile-trigger]");
        menu?.removeAttribute("hidden");
        trigger?.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
      }

      closeMenu() {
        const menu = this.querySelector("[data-mobile-menu]");
        const trigger = this.querySelector("[data-mobile-trigger]");
        const tier2Panel = this.querySelector("[data-tier2-panel]");
        const tier3Panel = this.querySelector("[data-tier3-panel]");
        const tier4Panel = this.querySelector("[data-tier4-panel]");

        menu?.setAttribute("hidden", "");
        trigger?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";

        tier2Panel?.classList.add("translate-x-full");
        tier3Panel?.classList.add("translate-x-full");
        tier4Panel?.classList.add("translate-x-full");

        this.querySelectorAll("[data-tier2-section]").forEach((s) => {
          s.hidden = true;
        });
        this.querySelectorAll("[data-tier3-section]").forEach((s) => {
          s.hidden = true;
        });
        this.querySelectorAll("[data-tier4-section]").forEach((s) => {
          s.hidden = true;
        });

        this.selectedTier1Key = null;
        this.selectedTier2Key = null;
        this.selectedTier3Key = null;
      }

      showTier2(tier1Key) {
        this.selectedTier1Key = tier1Key;

        this.querySelectorAll("[data-tier2-section]").forEach((section) => {
          section.hidden = section.dataset.tier2Section !== tier1Key;
        });

        const panel = this.querySelector("[data-tier2-panel]");
        panel?.classList.remove("translate-x-full");
      }

      hideTier2() {
        const panel = this.querySelector("[data-tier2-panel]");
        panel?.classList.add("translate-x-full");
        this.selectedTier1Key = null;
      }

      showTier3(tier2Key) {
        this.selectedTier2Key = tier2Key;

        this.querySelectorAll("[data-tier3-section]").forEach((section) => {
          section.hidden = section.dataset.tier3Section !== tier2Key;
        });

        const panel = this.querySelector("[data-tier3-panel]");
        panel?.classList.remove("translate-x-full");
      }

      hideTier3() {
        const panel = this.querySelector("[data-tier3-panel]");
        panel?.classList.add("translate-x-full");
        this.selectedTier2Key = null;
      }

      showTier4(tier3Key) {
        this.selectedTier3Key = tier3Key;

        this.querySelectorAll("[data-tier4-section]").forEach((section) => {
          section.hidden = section.dataset.tier4Section !== tier3Key;
        });

        const panel = this.querySelector("[data-tier4-panel]");
        panel?.classList.remove("translate-x-full");
      }

      hideTier4() {
        const panel = this.querySelector("[data-tier4-panel]");
        panel?.classList.add("translate-x-full");
        this.selectedTier3Key = null;
      }

      setupKeyboardHandlers() {
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") {
            const menu = this.querySelector("[data-mobile-menu]");
            if (menu && !menu.hasAttribute("hidden")) {
              this.closeMenu();
            }
          }
        });
      }
    }

    customElements.define("mobile-nav-controller", MobileNavController);
  </script>
</mobile-nav-controller>
