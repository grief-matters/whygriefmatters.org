---
import { paddingXSettingMap, paddingYSettingMap } from "@styles/utils/spacing";

import type { NavTreeNode } from "@ui/utils/main-nav";

import LayoutSurface from "@ui/base/LayoutSurface.astro";
import Button from "@ui/base/Button.astro";
import Stack from "@ui/base/Stack.astro";
import Typography from "@ui/base/Typography.astro";
import NavItem from "@ui/composite/content-linked/NavItem.astro";

interface Props {
  navTree: NavTreeNode[];
}

const { navTree } = Astro.props;

/**
 * Path-based stable keys for the controller's data attributes.
 * Top-level items are "0", "1", ...; children are "0.0", "0.1", ...
 */
const tier1Items = navTree.map((node, i) => ({
  key: String(i),
  node,
}));

const tier2Sections = tier1Items.flatMap(({ key: tier1Key, node }) => {
  if (node.kind !== "navItemGroup") return [];
  return [
    {
      tier1Key,
      tier2List: node.items.map((child, j) => ({
        key: `${tier1Key}.${j}`,
        node: child,
      })),
    },
  ];
});

const tier3Sections = tier2Sections.flatMap(({ tier2List }) =>
  tier2List.flatMap(({ key: tier2Key, node }) => {
    if (node.kind !== "navItemGroup") return [];
    return [
      {
        tier2Key,
        items: node.items,
      },
    ];
  }),
);
---

<desktop-nav-controller>
  <LayoutSurface colorVariant="primaryContrast" colorVariantKey={2}>
    <nav
      class="flex items-center justify-between gap-1 max-w-6xl mx-auto"
      data-desktop-nav
      aria-label="Main navigation"
    >
      {
        tier1Items.map(({ key, node }) =>
          node.kind === "navItemGroup" ? (
            <button
              type="button"
              data-tier1-btn={key}
              class:list={[
                "py-2",
                paddingXSettingMap[3],
                "cursor-pointer",
                "transition duration-300",
                "font-sans-a font-medium",
                "text-onSurface-primaryContrast--default",
                "bg-contentSurface-primaryContrast--prominent hover:bg-contentSurface-primaryContrast--default",
                "data-active:bg-contentSurface-primary--default data-active:text-onSurface-primary--default",
              ]}
              aria-expanded="false"
              aria-haspopup="true"
            >
              {node.label}
            </button>
          ) : (
            <div
              class:list={[
                "py-2",
                paddingXSettingMap[3],
                "font-sans-a font-medium",
                "text-onSurface-primaryContrast--default",
                "bg-contentSurface-primaryContrast--prominent",
              ]}
            >
              <NavItem
                node={node}
                variant="button-1"
                colorVariant="primaryContrast"
              />
            </div>
          ),
        )
      }
    </nav>
  </LayoutSurface>

  <!-- Desktop mega-nav -->
  <div
    data-mega-nav
    hidden
    class:list={[
      "shadow-lg",
      "absolute left-0 right-0 z-40",
      "max-w-7xl mx-auto",
      "bg-contentSurface-primary--default",
    ]}
  >
    <nav class="grid grid-cols-[280px_1fr]">
      <!-- Left pane: Tier 2 items -->
      <div data-mega-tier2-pane class="py-12">
        {
          tier2Sections.map(({ tier1Key, tier2List }) => (
            <ul data-mega-tier2-list={tier1Key} hidden>
              {tier2List.map(({ key, node }, i) =>
                node.kind === "navItemGroup" ? (
                  <li>
                    <button
                      type="button"
                      data-mega-tier2-btn={key}
                      data-parent-tier1={tier1Key}
                      data-first={i === 0 ? "" : undefined}
                      class:list={[
                        "font-bold font-serif text-left",
                        "cursor-pointer",
                        "w-full",
                        paddingXSettingMap[4],
                        paddingYSettingMap[2],
                        "text-onSurface-primary--default",
                        "transition-colors",
                        "hover:bg-layoutSurface-primary--1 data-active:bg-layoutSurface-neutral--1",
                        "border-l-4 border-transparent data-active:border-line-brand--accent",
                      ]}
                    >
                      {node.label}
                    </button>
                  </li>
                ) : (
                  <li
                    class:list={[
                      paddingXSettingMap[4],
                      paddingYSettingMap[2],
                      "border-l-4 border-transparent",
                    ]}
                  >
                    <NavItem
                      node={node}
                      variant="title-5"
                      colorVariant="primary"
                    />
                  </li>
                ),
              )}
            </ul>
          ))
        }
      </div>

      <!-- Right pane: Tier 3 items -->
      <div data-mega-tier3-pane class="py-4 px-8 bg-layoutSurface-neutral--1">
        {
          tier3Sections.map(({ tier2Key, items }) => (
            <div
              data-mega-tier3-section={tier2Key}
              hidden
              class="flex flex-col h-full"
            >
              <header class="flex justify-end mt-3 mb-4">
                <Button
                  data-mega-close
                  type="button"
                  styleVariant="outlined"
                  colorVariant="neutral"
                  textVariant="button-1"
                  label="Close"
                />
              </header>
              <ul class="space-y-3">
                {items.map((node) => (
                  <li>
                    {node.kind !== "navItemGroup" ? (
                      <NavItem
                        node={node}
                        variant="body-2"
                        colorVariant="warmNeutral"
                      />
                    ) : (
                      <Fragment>
                        <Typography
                          as="span"
                          variant="body-2"
                          colorVariant="warmNeutral"
                          set:text={node.label}
                        />
                        <div class="ml-4 mt-2 mb-1">
                          <Stack>
                            {node.items.map((child) => (
                              <div>
                                {child.kind !== "navItemGroup" ? (
                                  <NavItem
                                    node={child}
                                    colorVariant="warmNeutral"
                                  />
                                ) : (
                                  <Typography
                                    as="span"
                                    colorVariant="warmNeutral"
                                    set:text={child.label}
                                  />
                                )}
                              </div>
                            ))}
                          </Stack>
                        </div>
                      </Fragment>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </nav>
  </div>
</desktop-nav-controller>

<script is:inline>
  class DesktopNavController extends HTMLElement {
    selectedTier1Key = null;
    selectedTier2Key = null;

    connectedCallback() {
      this.setupHandlers();
      this.setupKeyboardHandlers();
    }

    setupHandlers() {
      this.querySelectorAll("[data-tier1-btn]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const tier1Key = btn.getAttribute("data-tier1-btn");
          if (this.selectedTier1Key === tier1Key) {
            this.closeMegaNav();
          } else {
            this.openMegaNav(tier1Key);
          }
        });
      });

      this.querySelectorAll("[data-mega-tier2-btn]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const tier2Key = btn.getAttribute("data-mega-tier2-btn");
          this.selectTier2(tier2Key);
        });
      });

      this.querySelectorAll("[data-mega-close]").forEach((btn) => {
        btn?.addEventListener("click", () => this.closeMegaNav());
      });

      document.addEventListener("click", (e) => {
        const megaNav = this.querySelector("[data-mega-nav]");
        if (megaNav && !megaNav.hasAttribute("hidden")) {
          const isInsideNav = this.contains(e.target);
          if (!isInsideNav) {
            this.closeMegaNav();
          }
        }
      });
    }

    openMegaNav(tier1Key) {
      this.selectedTier1Key = tier1Key;

      this.querySelectorAll("[data-tier1-btn]").forEach((btn) => {
        const btnKey = btn.getAttribute("data-tier1-btn");
        if (btnKey === tier1Key) {
          btn.setAttribute("data-active", "");
          btn.setAttribute("aria-expanded", "true");
        } else {
          btn.removeAttribute("data-active");
          btn.setAttribute("aria-expanded", "false");
        }
      });

      this.querySelectorAll("[data-mega-tier2-list]").forEach((list) => {
        list.hidden = list.dataset.megaTier2List !== tier1Key;
      });

      const firstTier2Btn = this.querySelector(
        `[data-mega-tier2-list="${tier1Key}"] [data-first]`,
      );
      if (firstTier2Btn) {
        const firstTier2Key = firstTier2Btn.getAttribute("data-mega-tier2-btn");
        this.selectTier2(firstTier2Key);
      } else {
        this.querySelectorAll("[data-mega-tier3-section]").forEach((s) => {
          s.hidden = true;
        });
      }

      const megaNav = this.querySelector("[data-mega-nav]");
      megaNav?.removeAttribute("hidden");
    }

    closeMegaNav() {
      const megaNav = this.querySelector("[data-mega-nav]");
      megaNav?.setAttribute("hidden", "");

      this.querySelectorAll("[data-tier1-btn]").forEach((btn) => {
        btn.removeAttribute("data-active");
        btn.setAttribute("aria-expanded", "false");
      });

      this.querySelectorAll("[data-mega-tier2-list]").forEach((list) => {
        list.hidden = true;
      });

      this.querySelectorAll("[data-mega-tier3-section]").forEach((section) => {
        section.hidden = true;
      });

      this.querySelectorAll("[data-mega-tier2-btn]").forEach((btn) => {
        btn.removeAttribute("data-active");
      });

      this.selectedTier1Key = null;
      this.selectedTier2Key = null;
    }

    selectTier2(tier2Key) {
      this.selectedTier2Key = tier2Key;

      this.querySelectorAll("[data-mega-tier2-btn]").forEach((btn) => {
        const btnKey = btn.getAttribute("data-mega-tier2-btn");
        if (btnKey === tier2Key) {
          btn.setAttribute("data-active", "");
        } else {
          btn.removeAttribute("data-active");
        }
      });

      this.querySelectorAll("[data-mega-tier3-section]").forEach((section) => {
        section.hidden = section.dataset.megaTier3Section !== tier2Key;
      });
    }

    setupKeyboardHandlers() {
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          const megaNav = this.querySelector("[data-mega-nav]");
          if (megaNav && !megaNav.hasAttribute("hidden")) {
            this.closeMegaNav();
          }
        }
      });
    }
  }

  customElements.define("desktop-nav-controller", DesktopNavController);
</script>
