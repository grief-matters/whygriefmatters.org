---
import { paddingXSettingMap } from "@styles/utils/spacing";

import type { NavTreeNode } from "@ui/utils/navigation-tree";

import IconTextButton from "@ui/base/IconTextButton.astro";
import LayoutSurface from "@ui/base/LayoutSurface.astro";
import NavTreeLink from "@ui/composite/content-linked/NavTreeLink.astro";

import MegaNavBranch from "./MegaNavBranch.astro";

interface Props {
  navTree: NavTreeNode[];
}

const { navTree } = Astro.props;

/**
 * Path-based stable keys for the controller's data attributes.
 * Top-level items are "0", "1", ...
 */
const tier1Items = navTree.map((node, i) => ({
  key: String(i),
  node,
}));

/**
 * One mega-nav panel per tier-1 group. Within a panel the tier-2 items split
 * into loose "navigation items" (leaves) and groups. Leaves are collected into
 * the first grid column; groups each occupy their own cell.
 */
const megaPanels = tier1Items.flatMap(({ key, node }) => {
  if (node.kind !== "navItemGroup") {
    return [];
  }

  const leaves = node.items.filter((item) => item.kind !== "navItemGroup");
  const groups = node.items.filter((item) => item.kind === "navItemGroup");

  return [{ key, leaves, groups }];
});
---

<desktop-nav-controller>
  <LayoutSurface colorVariant="primaryContrast" colorVariantKey={2}>
    <nav
      class="flex items-center justify-between gap-1 max-w-6xl mx-auto"
      data-desktop-nav
      aria-label="Main navigation"
    >
      {
        tier1Items.map(({ key, node }) =>
          node.kind === "navItemGroup" ? (
            <button
              type="button"
              data-tier1-btn={key}
              class:list={[
                "py-2",
                paddingXSettingMap[3],
                "cursor-pointer",
                "transition duration-300",
                "font-sans-a font-medium",
                "text-onSurface-primaryContrast--default",
                "bg-contentSurface-primaryContrast--prominent hover:bg-contentSurface-primaryContrast--default",
                "data-active:bg-contentSurface-primary--default data-active:text-onSurface-primary--default",
              ]}
              aria-expanded="false"
              aria-haspopup="true"
            >
              {node.label}
            </button>
          ) : (
            <div
              class:list={[
                "py-2",
                paddingXSettingMap[3],
                "font-sans-a font-medium",
                "text-onSurface-primaryContrast--default",
                "bg-contentSurface-primaryContrast--prominent",
              ]}
            >
              <NavTreeLink
                node={node}
                variant="button-1"
                colorVariant="primaryContrast"
              />
            </div>
          ),
        )
      }
    </nav>
  </LayoutSurface>

  <!-- Desktop mega-nav: fixed overlay acting as a modal underlay. It's anchored
       to the BOTTOM of the nav bar so the nav stays uncovered above it, and the
       blur/scrim fills the remaining viewport below. Clicking the backdrop
       closes it. `--mega-nav-top` is set on open (see openMegaNav). -->
  <div
    data-mega-nav
    class:list={[
      "group",
      // Note: `transition` (not `transition-all`) so the `top` change on open
      // isn't animated — only the blur + scrim fade.
      "transition duration-300",
      "fixed inset-x-0 bottom-0 z-40",
      "overflow-y-auto",
      // Closed: transparent + non-interactive so the transition has somewhere
      // to animate from and the invisible overlay doesn't swallow clicks.
      "pointer-events-none backdrop-blur-none bg-black/0",
      // Open: blur + scrim fade in.
      "data-open:pointer-events-auto data-open:backdrop-blur-xs data-open:bg-black/25",
    ]}
    style="top: var(--mega-nav-top, 0px);"
  >
    <div
      data-mega-panels
      class:list={[
        "shadow-lg",
        "bg-layoutSurface-neutral--1",
        // Clip during the height morph (box-shadow is unaffected by overflow).
        "overflow-hidden",
        // Fades in/out with the underlay; `height` is animated from JS when
        // switching between panels of differing heights.
        "opacity-0 transition-[opacity,height] duration-300 ease-out",
        "group-data-[open]:opacity-100",
      ]}
    >
      {
        megaPanels.map(({ key, leaves, groups }) => {
          // The leaf column spans the rows the groups occupy across the two
          // remaining columns; without leaves the groups use all three columns.
          const groupRows = leaves.length
            ? Math.max(1, Math.ceil(groups.length / 2))
            : undefined;

          return (
            <div
              data-mega-panel={key}
              hidden
              class:list={[
                "max-w-7xl mx-auto px-8 py-6",
                // Panel content fades independently of the box so it can be
                // staggered on open and cross-dissolved when switching panels.
                "opacity-0 transition-opacity duration-200 ease-out",
                "data-visible:opacity-100",
              ]}
            >
              <header class="flex justify-end mb-4">
                <IconTextButton
                  data-mega-close
                  getIcon={(icons) => icons.xMark}
                  label="Close"
                  iconPosition="end"
                />
              </header>

              <div class="grid grid-cols-3 lg:grid-cols-4 gap-x-8 gap-y-12 mb-16">
                {leaves.length > 0 && (
                  <ul
                    class="space-y-2"
                    style={`grid-column: 1; grid-row: 1 / span ${groupRows};`}
                  >
                    {leaves.map((node) => (
                      <li>
                        <NavTreeLink
                          node={node}
                          variant="title-5"
                          colorVariant="primary"
                        />
                      </li>
                    ))}
                  </ul>
                )}

                {groups.map((node) => (
                  <div>
                    <MegaNavBranch node={node} depth={0} />
                  </div>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</desktop-nav-controller>

<script is:inline>
  class DesktopNavController extends HTMLElement {
    selectedTier1Key = null;
    panelTimers = [];

    connectedCallback() {
      this.setupHandlers();
      this.setupKeyboardHandlers();
    }

    setupHandlers() {
      this.querySelectorAll("[data-tier1-btn]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const tier1Key = btn.getAttribute("data-tier1-btn");
          if (this.selectedTier1Key === tier1Key) {
            this.closeMegaNav();
          } else {
            this.openMegaNav(tier1Key);
          }
        });
      });

      this.querySelectorAll("[data-mega-close]").forEach((btn) => {
        btn?.addEventListener("click", () => this.closeMegaNav());
      });

      // Clicking the underlay itself (the blurred backdrop / nav region, i.e.
      // anywhere that isn't the panel content) closes it, like a modal.
      const megaNav = this.querySelector("[data-mega-nav]");
      megaNav?.addEventListener("click", (e) => {
        if (e.target === megaNav) {
          this.closeMegaNav();
        }
      });

      document.addEventListener("click", (e) => {
        const megaNav = this.querySelector("[data-mega-nav]");
        if (megaNav && megaNav.hasAttribute("data-open")) {
          const isInsideNav = this.contains(e.target);
          if (!isInsideNav) {
            this.closeMegaNav();
          }
        }
      });
    }

    openMegaNav(tier1Key) {
      const megaNav = this.querySelector("[data-mega-nav]");
      // Distinguish a fresh open (blur/box fade in, text staggered) from
      // switching panels while already open (cross-dissolve the text).
      const wasOpen = megaNav?.hasAttribute("data-open");
      this.selectedTier1Key = tier1Key;

      this.querySelectorAll("[data-tier1-btn]").forEach((btn) => {
        const btnKey = btn.getAttribute("data-tier1-btn");
        if (btnKey === tier1Key) {
          btn.setAttribute("data-active", "");
          btn.setAttribute("aria-expanded", "true");
        } else {
          btn.removeAttribute("data-active");
          btn.setAttribute("aria-expanded", "false");
        }
      });

      const nav = this.querySelector("[data-desktop-nav]");
      if (nav) {
        // Overlay starts at the nav's bottom edge so the nav stays uncovered.
        const bottom = nav.getBoundingClientRect().bottom;
        megaNav?.style.setProperty("--mega-nav-top", `${bottom}px`);
      }
      megaNav?.setAttribute("data-open", "");
      document.body.style.overflow = "hidden";

      this.activatePanel(tier1Key, { dissolve: wasOpen });
    }

    clearPanelTimers() {
      this.panelTimers.forEach(clearTimeout);
      this.panelTimers = [];
    }

    /**
     * Shows the panel for `key`, mounting/unmounting the others.
     * - Fresh open: fade the panel's text in after a short delay so it trails
     *   the box fade.
     * - Switching (`dissolve`): fade the current panel's text out, morph the
     *   box height from the old panel's to the new panel's, then fade the new
     *   text in — so panels of differing heights transition smoothly.
     */
    activatePanel(key, { dissolve } = {}) {
      this.clearPanelTimers();

      const box = this.querySelector("[data-mega-panels]");
      const panels = Array.from(this.querySelectorAll("[data-mega-panel]"));
      const next = panels.find((p) => p.dataset.megaPanel === key);
      if (!next) return;

      const current = panels.find((p) => p !== next && !p.hidden);

      const fadeInNext = () =>
        requestAnimationFrame(() =>
          requestAnimationFrame(() => next.setAttribute("data-visible", "")),
        );

      if (dissolve && current) {
        // 1) Fade the current text out.
        current.removeAttribute("data-visible");

        // 2) Once it's out, swap content and morph the box height.
        this.panelTimers.push(
          setTimeout(() => {
            const start = box ? box.offsetHeight : 0; // old panel height

            current.hidden = true;
            current.removeAttribute("data-visible");
            next.hidden = false;

            if (box) {
              const end = box.offsetHeight; // new panel's natural height
              box.style.height = `${start}px`;
              void box.offsetHeight; // reflow so the start height commits
              requestAnimationFrame(() => {
                box.style.height = `${end}px`;
              });
              // Release back to auto after the height transition completes.
              this.panelTimers.push(
                setTimeout(() => {
                  box.style.height = "";
                }, 300),
              );
            }

            // 3) Fade the new text in as the box settles.
            this.panelTimers.push(setTimeout(fadeInNext, 120));
          }, 200),
        );
      } else {
        // Fresh open: no height morph (box fades in at its natural size);
        // stagger the text so it trails the box fade.
        panels.forEach((p) => {
          p.hidden = p !== next;
          p.removeAttribute("data-visible");
        });
        if (box) box.style.height = "";
        this.panelTimers.push(
          setTimeout(() => next.setAttribute("data-visible", ""), 150),
        );
      }
    }

    closeMegaNav() {
      const megaNav = this.querySelector("[data-mega-nav]");
      megaNav?.removeAttribute("data-open");
      document.body.style.overflow = "";

      this.querySelectorAll("[data-tier1-btn]").forEach((btn) => {
        btn.removeAttribute("data-active");
        btn.setAttribute("aria-expanded", "false");
      });

      // Let the box (and its text) fade out with the underlay, then unmount.
      this.clearPanelTimers();
      const box = this.querySelector("[data-mega-panels]");
      this.panelTimers.push(
        setTimeout(() => {
          if (box) box.style.height = "";
          this.querySelectorAll("[data-mega-panel]").forEach((panel) => {
            panel.hidden = true;
            panel.removeAttribute("data-visible");
          });
        }, 300),
      );

      this.selectedTier1Key = null;
    }

    setupKeyboardHandlers() {
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          const megaNav = this.querySelector("[data-mega-nav]");
          if (megaNav && megaNav.hasAttribute("data-open")) {
            this.closeMegaNav();
          }
        }
      });
    }
  }

  customElements.define("desktop-nav-controller", DesktopNavController);
</script>
