---
import type { SanityImageData } from "@content/model/image";
import ContentSurface from "./ContentSurface.astro";
import SanityImageComp from "./SanityImage.astro";

interface Props {
  image: SanityImageData | null;
  name: string;
}

const { image, name } = Astro.props;
---

<ContentSurface
  paddingX={2}
  paddingY={2}
  variant="featureCard"
  class:list={["max-w-sm"]}
>
  {
    image !== null && (
      <SanityImageComp
        useFallback={false}
        aspect="square"
        image={{ image }}
        alt={`Headshot of ${name}`}
      />
    )
  }
</ContentSurface>
