---
import ContentSurface from "./ContentSurface.astro";
import SanityImageComp from "./SanityImage.astro";
import type { ImageAsset } from "@content/model/imageAsset";

interface Props {
  image: ImageAsset | null;
}

const { image } = Astro.props;
---

<ContentSurface
  paddingX={2}
  paddingY={2}
  variant="featureCard"
  class:list={["max-w-sm"]}
>
  {
    image !== null && (
      <SanityImageComp useFallback={false} aspect="square" image={image} />
    )
  }
</ContentSurface>
