---
import type { OnSurfaceColorVariant } from "@styles/utils/color";
import { type iconMap, type IconMapValue } from "@ui/utils/icon";

import Icon from "@ui/base/Icon.astro";
import Typography from "@ui/base/Typography.astro";

interface Props {
  getIcon: (icons: typeof iconMap) => IconMapValue;
  label: string;
  colorVariant?: OnSurfaceColorVariant;
  iconPosition?: "start" | "end";
}

const {
  getIcon,
  label,
  colorVariant = "primary",
  iconPosition = "start",
  ...attrs
} = Astro.props;
---

<button type="button" color="coolNeutral" {...attrs}>
  <span class="flex items-center gap-1">
    {iconPosition === "start" && <Icon colorVariant={colorVariant} getIcon={getIcon} />}
    <Typography variant="body-2" colorVariant={colorVariant} set:text={label} />
    {iconPosition === "end" && <Icon colorVariant={colorVariant} getIcon={getIcon} />}
  </span>
</button>
