---
import {
  standardVariantsClassMap,
  textColorMap,
  type OnSurfaceColorVariant,
  type SurfaceColorVariant,
} from "@styles/utils/color";
import { paddingXSettingMap } from "@styles/utils/spacing";
import { textPresetClassMap } from "@styles/utils/typography";
import type { HTMLAttributes } from "astro/types";

// or extend with an `interface`
interface Props extends HTMLAttributes<"button"> {
  label: string;
  colorVariant?: SurfaceColorVariant;
}

type SurfaceToOnSurfaceMap = Record<SurfaceColorVariant, OnSurfaceColorVariant>;

const surfaceToOnSurfaceMap: SurfaceToOnSurfaceMap = {
  neutral: "warmNeutral",
  primary: "primary",
  secondary: "secondary",
  tertiary: "tertiary",
  primaryContrast: "primaryContrast",
};

const { label, colorVariant = "neutral", ...attrs } = Astro.props;

const onSurfaceVariant = surfaceToOnSurfaceMap[colorVariant];
---

<button
  class:list={[
    standardVariantsClassMap[colorVariant]["muted"],
    textColorMap[onSurfaceVariant]["default"],
    textPresetClassMap["subtitle-1"],
    paddingXSettingMap[2],
    "py-1",
    "rounded-full",
    "flex items-center gap-1.5",
  ]}
  {...attrs}
>
  {label}
</button>
