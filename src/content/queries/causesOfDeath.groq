*[_type == 'causeOfDeath']{
  "id": _id,
  "slug": slug.current,
  title,
  displayTitle,
  shortDescription,
  description,
  causeCategory,
  "coverImage": coverImageRef->._id,
  searchAliases,
  "featuredResources": coalesce(featuredResources[]->{
    "refType": _type,
    "refId": _id
  }, []),
  "secondaryFeaturedResources": coalesce(secondaryFeaturedResources[]->{
    "refType": _type,
    "refId": _id
  }, []),
}
