*[_type == "wdynrnEntry"]{
  "id": _id,
  entryText,
  "destination": select(
    defined(causeOfDeath) => {"kind": "causeOfDeath", "ref": causeOfDeath->._id},
    defined(lossRelationship) => {"kind": "lossRelationship", "ref": lossRelationship->._id},
    defined(url) => {"kind": "url", "url": url}
  )
}
