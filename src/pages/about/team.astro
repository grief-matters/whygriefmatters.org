---
import { getCollection, getEntries, getEntry } from "astro:content";
import kebabCase from "lodash/kebabCase";

import type { SocialVal } from "@content/model/person";

import type { IconKey } from "@ui/utils/icon";

import { paddingBottomMap, marginBottomMap } from "@styles/utils/spacing";

import PageHeaderLayout from "@ui/layouts/PageHeaderLayout.astro";
import Section from "@ui/layouts/Section.astro";
import SitePageLayout from "@ui/layouts/SitePageLayout.astro";

import Icon from "@ui/base/Icon.astro";
import Link from "@ui/base/Link.astro";
// import PersonAvatar from "@ui/base/PersonAvatar.astro";
import PortableTextContentBlock from "@ui/base/PortableTextContentBlock.astro";
import Spacer from "@ui/base/Spacer.astro";
import Stack from "@ui/base/Stack.astro";
import Container from "@ui/base/Container.astro";
import Typography from "@ui/base/Typography.astro";
import Button from "@ui/base/Button.astro";

import ContentBlockRenderer from "@ui/composite/content-linked/content-block/ContentBlockRenderer.astro";
import PersonGroupRenderer from "@ui/composite/content-linked/content-block/PersonGroupRenderer.astro";

const contentGroup = await getCollection(
  "contentGroups",
  (col) => col.data.slug === "team",
);
if (contentGroup.length === 0) {
  throw new Error("Could not get team content group for team page");
}

// TODO: render content dynamically
const contentGroupData = contentGroup[0].data;

const leadInSection = contentGroupData.contentBlocks[0];
if (!leadInSection) {
  throw new Error("Could not get lead in section content block for team page");
}

const specialRecognitionSection = contentGroupData.contentBlocks[1];
if (!specialRecognitionSection) {
  throw new Error(
    "Could not get special recognition section content block for team page",
  );
}

const coreTeamSection = await getEntry(
  "personGroups",
  "97b9fbc2-3085-459f-8af8-38670b97d08c",
);
if (!coreTeamSection) {
  throw new Error("Could not get 'core team' for team page");
}

const coreTeamSectionMembers = await getEntries(
  coreTeamSection.data.members.map((x) => ({
    collection: x.collection,
    id: x.id,
  })),
);
if (!coreTeamSectionMembers || coreTeamSectionMembers.length === 0) {
  throw new Error("Could not get 'core team members' for team page");
}

const volunteerSection = await getEntry(
  "contentBlocks",
  contentGroupData.contentBlocks[2].id,
);
if (!volunteerSection) {
  throw new Error(
    "Could not get volunteer section content block for team page",
  );
}

const volunteerSectionTitle = volunteerSection.data.content.find(
  (contentItem) => contentItem.contentType === "headingText",
)?.text;
if (!volunteerSectionTitle) {
  throw new Error("Could not find title for volunteer section");
}

const volunteerSectionLeadin = volunteerSection.data.content.find(
  (contentItem) => contentItem.contentType === "richTextContentBlock",
)?.portableText;
if (!volunteerSectionLeadin) {
  throw new Error("Could not find lead in content for volunteer section");
}

const volunteerGroups = volunteerSection.data.content.filter(
  (contentItem) => contentItem.contentType === "personGroup",
);
if (volunteerGroups.length === 0) {
  throw new Error("Could not find any volunteer groups in volunteer section");
}

type SocialConfig = {
  type: SocialVal;
  hrefFn: (val: string) => string;
  icon: IconKey;
  a11yLabel: string;
};
const socialConfigMap: Record<SocialVal, SocialConfig> = {
  linkedIn: {
    type: "linkedIn",
    hrefFn: (val) => val,
    icon: "linkedIn",
    a11yLabel: "Linked In profile",
  },
  email: {
    type: "email",
    hrefFn: (val) => `mailto:${val}`,
    icon: "envelope",
    a11yLabel: "Email",
  },
};
---

<SitePageLayout>
  <PageHeaderLayout
    surfaceVariant="primaryContrast"
    surfaceVariantKey={1}
    image={null}
  >
    <Spacer marginBottom={3}>
      <Typography
        marginBottom={2}
        as="h1"
        variant="title-1"
        colorVariant="primaryContrast"
      >
        {"The Why Grief Matters Team"}
      </Typography>
    </Spacer>
    <Button
      as="a"
      colorVariant="secondary"
      href={`/about`}
      class="inline-block"
    >
      <Typography>
        {"Back to "}
        <strong class="text-bold">
          {"About Us"}
        </strong>
      </Typography>
    </Button>
  </PageHeaderLayout>
  <Section>
    {
      leadInSection && (
        <Stack spacing={4}>
          <ContentBlockRenderer
            textAlign="center"
            contentBlockRef={leadInSection}
          />
        </Stack>
      )
    }
  </Section>
  <Section colorVariantKey={3}>
    <Typography
      as="h2"
      variant="title-2"
      set:text="Core Team"
      marginBottom={3}
    />
    <Stack spacing={2}>
      {
        coreTeamSectionMembers.map((member) => (
          <div
            class:list={[
              paddingBottomMap[4],
              marginBottomMap[4],
              "not-last:border-b border-b-line-coolNeutral--default",
            ]}
          >
            <div
              class:list={[
                "space-y-3  md:gap-6",
                member.data.avatar && "md:grid md:grid-cols-[1fr_2fr]",
              ]}
            >
              {member.data.avatar && (
                <div class="flex justify-center md:block">
                  {/* <PersonAvatar
                    image={{ image: member.data.avatar, altText: "" }}
                  /> */}
                </div>
              )}
              <Stack spacing={2}>
                <div>
                  <Typography as="h3" variant="title-3">
                    {member.data.fullName}
                  </Typography>
                  <Typography variant="subtitle-1">
                    {member.data.role}
                  </Typography>
                </div>
                {member.data.shortBio && (
                  <PortableTextContentBlock
                    portableText={member.data.shortBio}
                  />
                )}
                {member.data.socials && (
                  <div class="flex gap-3">
                    {Object.entries(member.data.socials).map(([key, val]) => {
                      if (!val) {
                        return null;
                      }

                      const socialConfig = socialConfigMap[key as SocialVal];

                      return (
                        <a
                          class="text-onSurface-coolNeutral--muted"
                          href={socialConfig.hrefFn(val)}
                        >
                          <Icon
                            size={3}
                            getIcon={(icons) =>
                              icons[socialConfig.icon as IconKey]
                            }
                          />
                          <span class="sr-only">{socialConfig.a11yLabel}</span>
                        </a>
                      );
                    })}
                  </div>
                )}
                {member.data.personalStory && (
                  <Link
                    to={`/about/${kebabCase(member.data.fullName)}`}
                    label="Read More"
                  />
                )}
              </Stack>
            </div>
          </div>
        ))
      }
    </Stack>
  </Section>

  {
    specialRecognitionSection && (
      <Section>
        <ContentBlockRenderer
          textAlign="left"
          contentBlockRef={specialRecognitionSection}
        />
      </Section>
    )
  }
  {
    volunteerSection && (
      <Section colorVariantKey={3}>
        <Typography as="h2" variant="title-2" textAlign="center">
          {volunteerSectionTitle}
        </Typography>
        <Container paddingY={3}>
          <PortableTextContentBlock
            textAlign="left"
            portableText={volunteerSectionLeadin || []}
          />
        </Container>
        <Container paddingY={4}>
          <div class="columns-2">
            {volunteerGroups.map((group) => (
              <PersonGroupRenderer personGroupRef={group.refId.id} />
            ))}
          </div>
        </Container>
        <div class="text-center">
          <Link to={`/about`}>
            {"Back to "}
            <strong>{"About Us"}</strong>
          </Link>
        </div>
      </Section>
    )
  }
</SitePageLayout>
