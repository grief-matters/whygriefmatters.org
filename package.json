{
  "type": "module",
  "name": "whygriefmatters.org",
  "version": "1.0.0",
  "description": "The source code for the Grief Matters website. The best resources on grief and loss, all in one place.",
  "main": "index.js",
  "scripts": {
    "dev": "wrangler types && astro dev",
    "dev-host": "wrangler types && astro dev --host",
    "start": "wrangler types && astro dev",
    "build:astro": "astro build",
    "build:pagefind": "npx pagefind",
    "build": "wrangler types && astro check && astro build && pagefind",
    "preview": "wrangler types && wrangler dev --env dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.{ts,astro,css,json,md}'",
    "format:check": "prettier --check '**/*.{ts,astro,css,json,md}'",
    "typecheck": "astro check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grief-matters/whygriefmatters.org.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/grief-matters/whygriefmatters.org/issues"
  },
  "homepage": "https://github.com/grief-matters/whygriefmatters.org#readme",
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/cloudflare": "13.6.1",
    "@portabletext/to-html": "5.0.2",
    "@sanity/client": "7.22.1",
    "@sanity/image-url": "2.1.1",
    "@tailwindcss/vite": "4.3.0",
    "astro": "6.4.3",
    "clsx": "2.1.1",
    "lodash": "4.18.1",
    "resend": "^4.2.0",
    "sanitize-html": "^2.14.0",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.52.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/lodash": "4.17.24",
    "@types/node": "25.9.2",
    "@types/sanitize-html": "^2.13.0",
    "@typescript-eslint/parser": "8.52.0",
    "eslint": "9.39.2",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "groq": "5.30.0",
    "pagefind": "1.4.0",
    "prettier": "3.7.4",
    "prettier-plugin-astro": "0.14.1",
    "wrangler": "4.97.0"
  }
}
